    local count = 0
    
    BossTabBtn.BackgroundColor3 = (currentTab == "Bosses") and Color3.fromRGB(60, 60, 90) or Color3.fromRGB(45, 45, 45)
    EnemyTabBtn.BackgroundColor3 = (currentTab == "Enemies") and Color3.fromRGB(60, 60, 90) or Color3.fromRGB(45, 45, 45)

    for _, icon in pairs(EnemyDisplay:GetChildren()) do
        if icon:IsA("Frame") and string.find(icon.Name, "Icon") and icon.Name ~= "EnemyIconTemplate" then
            local npcName = string.gsub(icon.Name, "Icon", "")
            if filter == "" or string.find(safeLower(npcName), filter) then
                count = count + 1
                local btn = createBtn(npcName, UDim2.new(0,0,0,0), UDim2.new(1,-10,0,28), ListFrame)
                if selectedTargetName == npcName then btn.BackgroundColor3 = Color3.fromRGB(60, 60, 90) end
                btn.MouseButton1Click:Connect(function()
                    selectedTargetName = npcName
                    refreshNPCList()
                end)
            end
        end
    end
    ListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 33)
end

-- Force Fire Function: Tries all possible events
local function forceFire(button)
    if not button then return end
    local events = {"MouseButton1Click", "MouseButton1Down", "Activated", "MouseButton1Up"}
    for _, eventName in pairs(events) do
        pcall(function()
            local event = button[eventName]
            if event then
                for _, connection in pairs(getconnections(event)) do
                    connection:Fire()
                end
            end
        end)
    end
end

