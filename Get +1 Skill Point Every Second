-- Safe Helper
local function safeLower(val)
    return tostring(val or ""):lower()
end

-- Logic: NPC List Refresh
local function refreshNPCList()
    for _, child in pairs(ListFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    local filter = safeLower(SearchBar.Text)
    local count = 0
    BossTabBtn.BackgroundColor3 = (currentTab == "Bosses") and Color3.fromRGB(60, 60, 90) or Color3.fromRGB(45, 45, 45)
    EnemyTabBtn.BackgroundColor3 = (currentTab == "Enemies") and Color3.fromRGB(60, 60, 90) or Color3.fromRGB(45, 45, 45)

    for _, icon in pairs(EnemyDisplay:GetChildren()) do
        if icon:IsA("Frame") and string.find(icon.Name, "Icon") and icon.Name ~= "EnemyIconTemplate" then
            local npcName = string.gsub(icon.Name, "Icon", "")
            if filter == "" or string.find(safeLower(npcName), filter) then
                count = count + 1
                local btn = createBtn(npcName, UDim2.new(0,0,0,0), UDim2.new(1,-10,0,28), ListFrame)
                if selectedTargetName == npcName then btn.BackgroundColor3 = Color3.fromRGB(60, 60, 90) end
                btn.MouseButton1Click:Connect(function()
                    selectedTargetName = npcName
                    refreshNPCList()
                    cachedTarget = nil
                end)
            end
        end
    end
    ListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 33)
end

-- Logic: Auto-Select Best Weapon
local function getBestWeapon()
    local inventory = player.Backpack:GetChildren()
    local equipped = player.Character:GetChildren()
    local allTools = {}
    for _, v in pairs(inventory) do if v:IsA("Tool") then table.insert(allTools, v) end end
    for _, v in pairs(equipped) do if v:IsA("Tool") then table.insert(allTools, v) end end

    local referencePath = (currentToolType == "Physical") and PhysicalItemsPath or MagicalItemsPath
    local validWeaponNames = {}
    
    -- Gather names of tools that belong to the current category from game UI
    for _, template in pairs(referencePath:GetChildren()) do
        if template:IsA("Frame") and template.Name == "Template" then
            local realBtn = template:FindFirstChildOfClass("ImageButton")
            if realBtn then
                local toolName = string.gsub(realBtn.Name, "_Button", "")
                validWeaponNames[safeLower(toolName)] = true
            end
        end
    end

    -- Find tool in inventory that matches the category
    for _, tool in pairs(allTools) do
        if validWeaponNames[safeLower(tool.Name)] then
            return tool
        end
    end
    
    -- Fallback: If UI index isn't loaded, just return the first tool found in backpack as a last resort
    return player.Backpack:FindFirstChildOfClass("Tool") or player.Character:FindFirstChildOfClass("Tool")
end

