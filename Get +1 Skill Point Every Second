-- Safe Helper: Converts any input to a lowercase string
local function safeLower(val)
    return tostring(val or ""):lower()
end

-- Logic: Refresh Weapon List
local function refreshToolList()
    for _, child in pairs(ToolListFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    
    local path = (currentToolType == "Physical") and PhysicalItemsPath or MagicalItemsPath
    local filter = safeLower(WeaponSearchBar.Text)
    local count = 0
    
    PhysBtn.BackgroundColor3 = (currentToolType == "Physical") and Color3.fromRGB(70, 100, 70) or Color3.fromRGB(45, 45, 45)
    MagBtn.BackgroundColor3 = (currentToolType == "Magical") and Color3.fromRGB(70, 100, 70) or Color3.fromRGB(45, 45, 45)

    for _, template in pairs(path:GetChildren()) do
        if template:IsA("Frame") and template.Name == "Template" then
            local realBtn = template:FindFirstChildOfClass("ImageButton")
            if realBtn then
                local toolName = string.gsub(realBtn.Name, "_Button", "")
                if filter == "" or string.find(safeLower(toolName), filter) then
                    count = count + 1
                    local btn = createBtn(toolName, UDim2.new(0,0,0,0), UDim2.new(1,-10,0,25), ToolListFrame)
                    if selectedWeapon == toolName then btn.BackgroundColor3 = Color3.fromRGB(60, 80, 60) end
                    btn.MouseButton1Click:Connect(function()
                        selectedWeapon = toolName
                        refreshToolList()
                    end)
                end
            end
        end
    end
    ToolListFrame.CanvasSize = UDim2.new(0, 0, 0, count * 30)
end

-- Logic: Refresh NPC List
local function refreshNPCList()
