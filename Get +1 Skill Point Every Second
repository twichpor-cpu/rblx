-- RECURSIVE TARGET SEARCH (The Connection Fix)
-- This function finds the NPC even if it's buried in deep folders or has modifiers
local function getBestTarget()
    local char = player.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP or not selectedTargetName then return nil end

    local bestTarget = nil
    local minDistance = math.huge
    local cleanSelected = safeLower(selectedTargetName)

    -- Scans EVERYTHING in workspace recursively to find models matching the name
    for _, item in pairs(workspace:GetDescendants()) do
        if item:IsA("Model") and item ~= char then
            local modelName = safeLower(item.Name)
            
            -- Check if selected name is PART of the model's name (e.g., "Giant Slime" matches "Slime")
            if string.find(modelName, cleanSelected) then
                local hum = item:FindFirstChildOfClass("Humanoid")
                local hrp = item:FindFirstChild("HumanoidRootPart") or item:FindFirstChild("Torso") or item:FindFirstChild("Head")
                
                if hum and hum.Health > 0 and hrp then
                    local dist = (myHRP.Position - hrp.Position).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        bestTarget = item
                    end
                end
            end
        end
    end
    
    return bestTarget
end

-- Main Farm Loop
RunService.Heartbeat:Connect(function()
    if not isAutoFarming or not selectedTargetName then return end
    
    local char = player.Character
    if not char then return end

    local targetModel = getBestTarget()
    local targetHRP = targetModel and (targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Torso") or targetModel:FindFirstChild("Head"))
    local targetHum = targetModel and targetModel:FindFirstChildOfClass("Humanoid")
    
    if targetHRP and targetHum and targetHum.Health > 0 then
        StatusLabel.Text = "Status: Farming " .. targetModel.Name
        
        -- Tool Handling
        local tool = char:FindFirstChild(selectedWeapon)
        if not tool then
            local bpTool = player.Backpack:FindFirstChild(selectedWeapon)
            if bpTool and char:FindFirstChildOfClass("Humanoid") then
                char:FindFirstChildOfClass("Humanoid"):EquipTool(bpTool)
                tool = bpTool
            end
        end

        if tool then
            -- Position & Attack
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Move below target
                hrp.CFrame = CFrame.new(targetHRP.Position - Vector3.new(0, farmDistance, 0), targetHRP.Position)
                hrp.Velocity = Vector3.new(0,0,0)
            end
            
            -- Activation
            if tool.Parent == char then
                tool:Activate()
            end
        end
    else
        StatusLabel.Text = "Status: Connecting to " .. selectedTargetName .. "..."
        -- Brute force swing to ensure hits on transition
        if selectedWeapon then
            local tool = char:FindFirstChild(selectedWeapon) or player.Backpack:FindFirstChild(selectedWeapon)
            if tool and tool.Parent == char then tool:Activate() end
        end
    end
end)

