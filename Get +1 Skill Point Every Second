-- Target Logic
local function getBestTarget()
    local char = player.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP or not selectedTargetName then return nil end

    if cachedTarget and cachedTarget.Parent and cachedTarget:FindFirstChildOfClass("Humanoid") then
        if cachedTarget:FindFirstChildOfClass("Humanoid").Health > 0 then return cachedTarget end
    end

    local currentTime = tick()
    if currentTime - lastScanTime < scanInterval then return cachedTarget end
    lastScanTime = currentTime

    local bestTarget = nil
    local minDistance = math.huge
    local cleanSelected = safeLower(selectedTargetName)

    for _, item in pairs(workspace:GetDescendants()) do
        if item:IsA("Model") and item ~= char then
            if string.find(safeLower(item.Name), cleanSelected) then
                local hum = item:FindFirstChildOfClass("Humanoid")
                local hrp = item:FindFirstChild("HumanoidRootPart") or item:FindFirstChild("Torso") or item:FindFirstChild("Head")
                if hum and hum.Health > 0 and hrp then
                    local dist = (myHRP.Position - hrp.Position).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        bestTarget = item
                    end
                end
            end
        end
    end
    cachedTarget = bestTarget
    return bestTarget
end

-- Main Loop
RunService.Heartbeat:Connect(function()
    if not isAutoFarming then return end
    local char = player.Character
    if not char then return end

    local targetModel = getBestTarget()
    local targetHRP = targetModel and (targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Torso") or targetModel:FindFirstChild("Head"))
    
    if targetHRP and targetModel:FindFirstChildOfClass("Humanoid").Health > 0 then
        StatusLabel.Text = "Status: Farming " .. targetModel.Name
        
        local tool = getBestWeapon()
        if tool then
            if tool.Parent ~= char then
                char:FindFirstChildOfClass("Humanoid"):EquipTool(tool)
            end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame = CFrame.new(targetHRP.Position - Vector3.new(0, farmDistance, 0), targetHRP.Position)
                hrp.Velocity = Vector3.new(0,0,0)
            end
            tool:Activate()
        else
            StatusLabel.Text = "Status: No " .. currentToolType .. " Tool Found!"
        end
    else
        StatusLabel.Text = "Status: Searching for " .. (selectedTargetName or "Target")
    end
end)

