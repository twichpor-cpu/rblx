-- --- DYNAMIC ZONE SCANNING ---
local function GetZoneOptions(category)
    local options = {"None"}
    local path = Workspace:FindFirstChild("Main")
    if path then path = path:FindFirstChild("TrainingAreasHitBoxes") end
    if path then path = path:FindFirstChild(category) end
    
    if path then
        for _, obj in pairs(path:GetChildren()) do
            if obj:IsA("BasePart") then
                table.insert(options, obj.Name)
            end
        end
    end
    return options
end

-- --- AUTO FARM LOGIC ---
local function MakeFarmBtn(txt, remoteName)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 220, 0, 45)
    b.Text = txt .. " [OFF]"
    b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    b.TextColor3 = Color3.new(1, 1, 1)
    b.Parent = AutoPage
    
    local active = false
    b.MouseButton1Click:Connect(function()
        active = not active
        b.Text = txt .. (active and " [ON]" or " [OFF]")
        b.BackgroundColor3 = active and Color3.fromRGB(0, 150, 100) or Color3.fromRGB(45, 45, 45)
        
        task.spawn(function()
            -- Loop checks both the button state and the global script state
            while active and scriptRunning do
                local remote = Remotes:FindFirstChild(remoteName)
                if remote then remote:FireServer() end
                task.wait(0.1)
            end
        end)
    end)
end

MakeFarmBtn("Fist Strength", "FS_Train")
MakeFarmBtn("Body Toughness", "BT_Train")

-- --- ZONE SELECTION LOGIC ---
local activeZones = {BT = nil, FS = nil, PS = nil}
local originalPositions = {} -- Stores {part: Part, cf: CFrame, parent: Instance}

local function ReturnZone(category)
    local part = activeZones[category]
    if part and originalPositions[part] then
        part.CFrame = originalPositions[part].cf
        part.Parent = originalPositions[part].parent
        originalPositions[part] = nil
        activeZones[category] = nil
    end
end

local function SetZone(category, zoneName)
    -- Return current active zone to its spot first
    ReturnZone(category)
    
    if zoneName == "None" then return end
    
    local path = Workspace:FindFirstChild("Main")
    if path then path = path:FindFirstChild("TrainingAreasHitBoxes") end
    if path then path = path:FindFirstChild(category) end
    
    local part = path and path:FindFirstChild(zoneName)
    if part and part:IsA("BasePart") then
        -- Save original state
        originalPositions[part] = {
            cf = part.CFrame,
            parent = part.Parent
        }
        
        activeZones[category] = part
        
        task.spawn(function()
            -- Loop checks both the zone active status and the global script state
            while activeZones[category] == part and scriptRunning do
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    part.CFrame = root.CFrame
                end
                task.wait()
            end
        end)
    end
end

local function CreateDropdown(labelTxt, category)
    local options = GetZoneOptions(category)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, 220, 0, 60)
    container.BackgroundTransparency = 1
    container.Parent = ZonePage
    
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Text = labelTxt
    lbl.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    lbl.BackgroundTransparency = 1
    lbl.Parent = container
    
    local dropBtn = Instance.new("TextButton")
    dropBtn.Size = UDim2.new(1, 0, 0, 35)
    dropBtn.Position = UDim2.new(0, 0, 0, 20)
    dropBtn.Text = "Select " .. category .. "..."
    dropBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    dropBtn.TextColor3 = Color3.new(1, 1, 1)
    dropBtn.Parent = container
    
    local list = Instance.new("ScrollingFrame")
    list.Size = UDim2.new(1, 0, 0, math.min(#options * 30, 150))
    list.Position = UDim2.new(0, 0, 1, 0)
    list.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    list.Visible = false
    list.ZIndex = 10
    list.CanvasSize = UDim2.new(0, 0, 0, #options * 30)
    list.ScrollBarThickness = 4
    list.Parent = dropBtn
    
    local ll = Instance.new("UIListLayout")
    ll.Parent = list
    
    dropBtn.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
    end)
    
    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 30)
        optBtn.Text = opt
        optBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        optBtn.TextColor3 = Color3.new(1, 1, 1)
        optBtn.ZIndex = 11
        optBtn.Parent = list
        
        optBtn.MouseButton1Click:Connect(function()
            dropBtn.Text = opt
            list.Visible = false
            SetZone(category, opt)
        end)
    end
end

