-- Custom Frame Dragging (Smooth & Independent of Roblox legacy draggable property)
local dragToggle, dragStart, startPos
Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggle = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragToggle and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

--// 3. UI CONSOLE LOG WRITER
local function WriteToLog(text, color)
    if not _G.SpyActive then return end
    color = color or Color3.fromRGB(230, 230, 230)
    
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.Font = Enum.Font.Code
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Top
    label.TextWrapped = true
    
    -- Calculate height dynamically based on the width of the display frame
    local textWidth = LogDisplay.AbsoluteSize.X - 15
    local textHeight = TextService:GetTextSize(text, 11, Enum.Font.Code, Vector2.new(textWidth, 10000)).Y
    label.Size = UDim2.new(1, -10, 0, textHeight + 2)
    label.Parent = LogDisplay
    
    -- Force render stepping update to get accurate content size
    RunService.RenderStepped:Wait()
    LogDisplay.CanvasSize = UDim2.new(0, 0, 0, LogListLayout.AbsoluteContentSize.Y + 10)
    LogDisplay.CanvasPosition = Vector2.new(0, LogDisplay.CanvasSize.Y.Offset)
end

local function formatArgs(args)
    local success, result = pcall(function()
        return HttpService:JSONEncode(args)
    end)
    return success and result or tostring(args)
end

--// 4. ACTIVE DIAGNOSTIC LISTENERS
-- Input Listener
Connections["InputBegan"] = UserInputService.InputBegan:Connect(function(input, processed)
    if not _G.SpyActive then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        WriteToLog(string.format("[Key Press] Key: %s | GUI Focused: %s", tostring(input.KeyCode.Name), tostring(processed)), Color3.fromRGB(255, 230, 100))
    end
end)

Connections["InputEnded"] = UserInputService.InputEnded:Connect(function(input, processed)
    if not _G.SpyActive then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        WriteToLog(string.format("[Key Release] Key: %s", tostring(input.KeyCode.Name)), Color3.fromRGB(220, 200, 90))
    end
end)

-- Metamethod Spy (Intercept network events on trigger)
local success, err = pcall(function()
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        if not _G.SpyActive then 
            return oldNamecall(self, ...) 
        end
        
        local method = getnamecallmethod()
        local args = {...}
        
        if (method == "FireServer" or method == "InvokeServer") and self.Name ~= "Spy" then
            -- Safely pass the log calculation out of the namecall step to prevent performance drop
            task.spawn(function()
                WriteToLog(string.format("[Network] Outbound: %s\n   ↳ Path: %s\n   ↳ Payload: %s", method, self:GetFullName(), formatArgs(args)), Color3.fromRGB(0, 180, 214))
            end)
        end
        return oldNamecall(self, ...)
    end)
end)

if not success then
    WriteToLog("[Metamethod Fail] Hookmetamethod blocked by executor. Remote logging disabled.", Color3.fromRGB(240, 70, 70))
end

-- Animation Trigger Tracking
local function trackAnimations(char)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not humanoid then return end
    
    Connections["AnimationPlayed"] = humanoid.AnimationPlayed:Connect(function(track)
        if not _G.SpyActive then return end
        WriteToLog(string.format("[Anim Started] Name: %s | ID: %s", track.Name or "None", track.Animation.AnimationId), Color3.fromRGB(150, 240, 150))
    end)
end

-- Character Modification/Attribute Tracking
local function trackCharacterChanges(char)
    Connections["ChildAdded"] = char.ChildAdded:Connect(function(child)
        if not _G.SpyActive then return end
        WriteToLog(string.format("[Character Object Added] %s (%s)", child.Name, child.ClassName), Color3.fromRGB(240, 150, 240))
        
        if child:IsA("ValueBase") then
            child.Changed:Connect(function(newVal)
                if not _G.SpyActive then return end
                WriteToLog(string.format("[Value Change] %s changed to: %s", child.Name, tostring(newVal)), Color3.fromRGB(240, 180, 240))
            end)
        end
    end)

    Connections["AttributeChanged"] = char.AttributeChanged:Connect(function(attribute)
        if not _G.SpyActive then return end
        WriteToLog(string.format("[Attribute Changed] %s: %s", attribute, tostring(char:GetAttribute(attribute))), Color3.fromRGB(180, 150, 240))
    end)
end

-- Hook onto current and future characters
if Character then
    trackAnimations(Character)
    trackCharacterChanges(Character)
end

Connections["CharacterAdded"] = LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    trackAnimations(newChar)
    trackCharacterChanges(newChar)
end)

