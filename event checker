--// 1. CLEANUP & STOP ENGINE
local function CleanUp()
    _G.SpyActive = false -- Instantly bypasses the namecall remote hook
    
    -- Safely disconnect all events
    for name, conn in pairs(Connections) do
        if conn then
            conn:Disconnect()
        end
    end
    Connections = {}
    
    -- Destroy UI elements completely
    local oldGui = PlayerGui:FindFirstChild("NexusSpy_UI")
    if oldGui then
        oldGui:Destroy()
    end
    
    print("[SPY TERMINATED] All listeners disconnected and UI destroyed successfully.")
end

-- Force terminate any existing spy scripts before spawning a new one
local oldGui = PlayerGui:FindFirstChild("NexusSpy_UI")
if oldGui then
    CleanUp()
    task.wait(0.1)
end

