-- HELPER FUNCTIONS FOR UI
local function CreateToggle(parent, text, stateTable, stateKey, callback)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -10, 0, 30)
    frame.BackgroundTransparency = 1
    
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0, 24, 0, 24)
    btn.Position = UDim2.new(0, 5, 0, 3)
    btn.Text = stateTable[stateKey] and "X" or ""
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.TextColor3 = Color3.new(1,1,1)
    
    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1, -40, 1, 0)
    lbl.Position = UDim2.new(0, 35, 0, 0)
    lbl.Text = text
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    btn.MouseButton1Click:Connect(function()
        stateTable[stateKey] = not stateTable[stateKey]
        btn.Text = stateTable[stateKey] and "X" or ""
        if callback then callback(stateTable[stateKey]) end
    end)
    return frame, btn
end

