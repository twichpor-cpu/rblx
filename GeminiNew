-- DYNAMIC ITEM LISTING
local ItemButtons = {}
local function UpdateItemListUI()
    -- Clear current buttons
    for _, btn in pairs(ItemButtons) do btn:Destroy() end
    table.clear(ItemButtons)

    for itemName, data in pairs(TrackedItems) do
        local count = #data
        if count > 0 then
            local btn = Instance.new("TextButton", ItemTab)
            btn.Size = UDim2.new(1, -10, 0, 25)
            btn.Position = UDim2.new(0, 5, 0, 0)
            btn.Text = itemName .. " x" .. tostring(count)
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.MouseButton1Click:Connect(function()
                -- TP to the first one in the list
                local target = TrackedItems[itemName][1]
                if target and target.Parent then
                    local isLower = (itemName == "Frog" or itemName == "Banknote")
                    TeleportTo(target:IsA("Model") and target.PrimaryPart or target, isLower)
                end
            end)
            table.insert(ItemButtons, btn)
        end
    end
    ItemTab.CanvasSize = UDim2.new(0, 0, 0, ItemTab.UIListLayout.AbsoluteContentSize.Y + 10)
    SellTab.CanvasSize = UDim2.new(0, 0, 0, SellTab.UIListLayout.AbsoluteContentSize.Y + 10)
    PickupTab.CanvasSize = UDim2.new(0, 0, 0, PickupTab.UIListLayout.AbsoluteContentSize.Y + 10)
end

-- ==========================================
-- MAIN LOGIC LOOPS & EVENTS
-- ==========================================

local function HandleNewItem(inst)
    if not inst:IsA("Tool") and not inst:IsA("Model") and not inst:IsA("BasePart") then return end
    
    local pos = inst:IsA("Model") and (inst.PrimaryPart and inst.PrimaryPart.Position) or inst.Position
    if not pos then return end

    if IsInValidZone(pos) and IsSafeItem(inst) then
        local name = inst.Name
        if not TrackedItems[name] then TrackedItems[name] = {} end
        table.insert(TrackedItems[name], inst)
        UpdateItemListUI()

        -- Cleanup when picked up/despawned
        inst.AncestryChanged:Connect(function(_, newParent)
            if newParent ~= Workspace and newParent ~= Workspace:FindFirstChild("ItemSpawnAreas") then
                local idx = table.find(TrackedItems[name], inst)
                if idx then 
                    table.remove(TrackedItems[name], idx) 
                    UpdateItemListUI()
                end
            end
        end)
    end
end

Workspace.DescendantAdded:Connect(HandleNewItem)

-- Initial scan
for _, v in ipairs(Workspace:GetDescendants()) do
    HandleNewItem(v)
end

-- Logic Loop
RunService.Heartbeat:Connect(function()
    -- 1. Auto Collect Notes
    if Toggles.AutoCollectNotes then
        local note = Workspace:FindFirstChild("Banknote")
        if note then TeleportTo(note, true) end
    end

    -- 2. Auto Sell
    if Toggles.AutoSell then
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        local charTools = Character:GetChildren()
        
        local allTools = backpack and backpack:GetChildren() or {}
        for _, t in ipairs(charTools) do table.insert(allTools, t) end

        for _, tool in ipairs(allTools) do
            if tool:IsA("Tool") and SellFilters[tool.Name] == false then
                -- Equip and sell
                local hum = Character:FindFirstChild("Humanoid")
                if hum then
                    hum:EquipTool(tool)
                    task.wait(0.1) -- Small delay to ensure equip registers
                    local remote = ReplicatedStorage:FindFirstChild("BismalqStuff")
                    if remote then
                        remote:WaitForChild("Remotes"):WaitForChild("Sell"):FireServer()
                    end
                end
            end
        end
    end

    -- 3. Auto Pickup
    if Toggles.AutoPickup then
        for name, state in pairs(PickupFilters) do
            if state and TrackedItems[name] and #TrackedItems[name] > 0 then
                local target = TrackedItems[name][1]
                if target and target.Parent then
                    local isLower = (name == "Frog" or name == "Banknote")
                    TeleportTo(target:IsA("Model") and target.PrimaryPart or target, isLower)
                    task.wait(0.5) -- Prevent teleport spam
                end
            end
        end
    end
end)

