-- ==========================================
-- SPATIAL & SAFETY CHECKS
-- ==========================================

local ZonePos = Vector3.new(5662.36, 720.27, -1317.86)
local ZoneSize = Vector3.new(867, 89, 783)
local MinBounds = ZonePos - (ZoneSize / 2)
local MaxBounds = ZonePos + (ZoneSize / 2)

local function IsInValidZone(pos)
    -- Check Global Coordinates Box
    if (pos.X >= MinBounds.X and pos.X <= MaxBounds.X) and
       (pos.Y >= MinBounds.Y and pos.Y <= MaxBounds.Y) and
       (pos.Z >= MinBounds.Z and pos.Z <= MaxBounds.Z) then
        return true
    end

    -- Check ItemSpawnAreas
    local spawnAreas = Workspace:FindFirstChild("ItemSpawnAreas")
    if spawnAreas then
        for _, area in ipairs(spawnAreas:GetChildren()) do
            if area:IsA("BasePart") then
                local half = area.Size / 2
                local minA = area.Position - half
                local maxA = area.Position + half
                if (pos.X >= minA.X and pos.X <= maxA.X) and
                   (pos.Y >= minA.Y and pos.Y <= maxA.Y) and
                   (pos.Z >= minA.Z and pos.Z <= maxA.Z) then
                    return true
                end
            end
        end
    end
    return false
end

local function IsSafeItem(itemPart)
    -- Anti-cheat check: Ensures there are environment blocks near the item
    local params = OverlapParams.new()
    params.FilterDescendantsInstances = {itemPart}
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    local partsNear = Workspace:GetPartBoundsInRadius(itemPart.Position, 8, params)
    local environmentBlocks = 0
    for _, part in ipairs(partsNear) do
        if part:IsA("BasePart") and part.CanCollide then
            environmentBlocks = environmentBlocks + 1
        end
    end
    return environmentBlocks >= 1 -- Valid if at least 1 other physical block is nearby
end

local function TeleportTo(part, isLower)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root and part then
        local offset = isLower and Vector3.new(0, 3, 0) or Vector3.new(0, 0, 0)
        root.CFrame = CFrame.new(part.Position - offset)
    end
end

