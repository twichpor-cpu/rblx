--[[ 
    ULTRA-OPTIMIZED ITEM TRACKER (V6)
    Features: HH:MM:SS Clock, Persistent UI, Distance Tracking
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Player = Players.LocalPlayer

-- Configuration
local BoxSize = Vector3.new(867, 89, 783)
local BoxPos = Vector3.new(5662.36, 720.27, -1317.86)
local SpawnAreas = workspace:FindFirstChild("ItemSpawnAreas")
local CollectNotes = false

-- Helper: Format Seconds to HH:MM:SS
local function formatTime(s)
    local hours = math.floor(s / 3600)
    local mins = math.floor((s % 3600) / 60)
    local secs = math.floor(s % 60)
    return string.format("%02d:%02d:%02d", hours, mins, secs)
end

-- Helper: Get Position Safely
local function getPos(obj)
    local p = obj:IsA("BasePart") and obj or obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    return p and p.Position
end

-- IY-Style Teleport
local function teleport(pos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and pos then
        root.CFrame = CFrame.new(pos) + Vector3.new(0, 3, 0)
    end
end

-- GUI Setup
local ScreenGui = Instance.new("ScreenGui", Player:WaitForChild("PlayerGui"))
ScreenGui.Name = "PersistentTracker_V6"
ScreenGui.ResetOnSpawn = false 

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 240, 0, 380)
MainFrame.Position = UDim2.new(0.1, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.BorderSizePixel = 0

local TitleBar = Instance.new("TextLabel", MainFrame)
TitleBar.Size = UDim2.new(1, 0, 0, 30)
TitleBar.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
TitleBar.Text = "SERVER: 00:00:00"
TitleBar.TextColor3 = Color3.new(1, 1, 1)
TitleBar.Font = Enum.Font.Code

local NoteBtn = Instance.new("TextButton", MainFrame)
NoteBtn.Size = UDim2.new(0.9, 0, 0, 35)
NoteBtn.Position = UDim2.new(0.05, 0, 0.1, 0)
NoteBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
NoteBtn.Text = "Collect Banknotes: OFF"
NoteBtn.TextColor3 = Color3.new(1, 1, 1)

local ListContainer = Instance.new("ScrollingFrame", MainFrame)
ListContainer.Size = UDim2.new(1, 0, 1, -110)
ListContainer.Position = UDim2.new(0, 0, 0, 110)
ListContainer.BackgroundTransparency = 1
Instance.new("UIListLayout", ListContainer)

-- Drag Logic
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

NoteBtn.MouseButton1Click:Connect(function()
    CollectNotes = not CollectNotes
    NoteBtn.Text = "Collect Banknotes: " .. (CollectNotes and "ON" or "OFF")
    NoteBtn.BackgroundColor3 = CollectNotes and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(150, 50, 50)
end)

-- Main Optimized Loop
task.spawn(function()
    while task.wait(0.5) do
        -- Update Server Time to HH:MM:SS
        TitleBar.Text = "SERVER: " .. formatTime(time())
        
        local counts = {}
        local firstPos = {}
        local char = Player.Character
        local myPos = (char and char:FindFirstChild("HumanoidRootPart")) and char.HumanoidRootPart.Position or Vector3.new(0,0,0)

        local function scanFolder(folder)
            if not folder then return end
            for _, obj in pairs(folder:GetChildren()) do
                if obj:IsA("Model") and Players:GetPlayerFromCharacter(obj) then continue end
                
                if CollectNotes and obj.Name == "Banknote" then
                    local p = getPos(obj)
                    if p then teleport(p) end
                end

                if obj:IsA("Tool") then
                    local p = getPos(obj)
                    if p then
                        local dist = math.floor((myPos - p).Magnitude)
                        local min = BoxPos - (BoxSize / 2)
                        local max = BoxPos + (BoxSize / 2)
                        
                        if (p.X >= min.X and p.X <= max.X) and (p.Y >= min.Y and p.Y <= max.Y) and (p.Z >= min.Z and p.Z <= max.Z) then
                            counts[obj.Name] = (counts[obj.Name] or 0) + 1
                            if not firstPos[obj.Name] or dist < firstPos[obj.Name].dist then
                                firstPos[obj.Name] = {pos = p, dist = dist}
                            end
                        end
                    end
                end
            end
        end

        scanFolder(workspace)
        scanFolder(SpawnAreas)

        for _, v in pairs(ListContainer:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end

        for name, data in pairs(firstPos) do
            local b = Instance.new("TextButton", ListContainer)
            b.Size = UDim2.new(1, -10, 0, 30)
            b.BackgroundTransparency = 0.8
            b.Text = string.format(" %s x%d [%dm]", name, counts[name], data.dist)
            b.TextColor3 = Color3.new(1, 1, 1)
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.MouseButton1Click:Connect(function() teleport(data.pos) end)
        end
    end
end)
