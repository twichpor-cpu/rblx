local function openFilter(mode)
    FilterFrame.Visible = true
    for _, v in pairs(FilterScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, v in pairs(BulkActions:GetChildren()) do v:Destroy() end

    local function updateAll(val)
        for _, name in pairs(defaultItems) do if mode == "SELL" then SellFilter[name] = val else PickupFilter[name] = val end end
        openFilter(mode)
    end

    local allBtn = Instance.new("TextButton", BulkActions); allBtn.Size = UDim2.new(0.5,0,1,0); allBtn.Text = "ALL"; allBtn.BackgroundColor3 = Color3.fromRGB(50,100,50); allBtn.MouseButton1Click:Connect(function() updateAll(true) end)
    local noneBtn = Instance.new("TextButton", BulkActions); noneBtn.Size = UDim2.new(0.5,0,1,0); noneBtn.Position = UDim2.new(0.5,0,0,0); noneBtn.Text = "NONE"; noneBtn.BackgroundColor3 = Color3.fromRGB(100,50,50); noneBtn.MouseButton1Click:Connect(function() updateAll(false) end)

    for _, name in pairs(defaultItems) do
        local b = Instance.new("TextButton", FilterScroll); b.Size = UDim2.new(1, 0, 0, 25); b.TextColor3 = Color3.new(1,1,1); b.TextSize = 12
        local function updateStyle()
            if mode == "SELL" then
                b.Text = name .. (SellFilter[name] and ": KEEP" or ": SELL")
                b.BackgroundColor3 = SellFilter[name] and Color3.fromRGB(20, 60, 20) or Color3.fromRGB(60, 20, 20)
            else
                b.Text = name .. (PickupFilter[name] and ": PICKUP" or ": IGNORE")
                b.BackgroundColor3 = PickupFilter[name] and Color3.fromRGB(20, 60, 20) or Color3.fromRGB(60, 20, 20)
            end
        end
        b.MouseButton1Click:Connect(function() if mode == "SELL" then SellFilter[name] = not SellFilter[name] else PickupFilter[name] = not PickupFilter[name] end; updateStyle() end)
        updateStyle()
    end
end

