-- Helper: Precise Ground Teleport
local function teleport(pos, itemName)
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if root then 
        local groundItems = {["Frog"]=true, ["Unfair Frog"]=true, ["Banknote"]=true, ["troll banknote"]=true}
        local finalPos = groundItems[itemName] and (pos - Vector3.new(0, 0.5, 0)) or pos
        root.CFrame = CFrame.new(finalPos) 
    end
end

