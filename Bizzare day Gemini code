-- Helper: Teleport
local function teleport(pos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(pos) + Vector3.new(0, 2, 0)
    end
end

