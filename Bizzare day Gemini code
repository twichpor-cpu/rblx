-- Filter Menu Builder
local function openFilter(mode)
    FilterFrame.Visible = true
    for _, v in pairs(FilterScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    FilterTitle.Text = mode == "SELL" and "SELL FILTER (Red=Sell)" or "PICKUP FILTER (Green=Get)"
    
    for _, name in pairs(defaultItems) do
        local b = Instance.new("TextButton", FilterScroll)
        b.Size = UDim2.new(1, 0, 0, 25); b.TextColor3 = Color3.new(1,1,1); b.BorderSizePixel = 0
        
        local function updateStyle()
            if mode == "SELL" then
                b.Text = name .. (SellFilter[name] and ": KEEP" or ": SELL")
                b.BackgroundColor3 = SellFilter[name] and Color3.fromRGB(20, 60, 20) or Color3.fromRGB(60, 20, 20)
            else
                b.Text = name .. (PickupFilter[name] and ": PICKUP" or ": IGNORE")
                b.BackgroundColor3 = PickupFilter[name] and Color3.fromRGB(20, 60, 20) or Color3.fromRGB(60, 20, 20)
            end
        end
        
        b.MouseButton1Click:Connect(function()
            if mode == "SELL" then SellFilter[name] = not SellFilter[name] else PickupFilter[name] = not PickupFilter[name] end
            updateStyle()
        end)
        updateStyle()
    end
end

PickFilterBtn.MouseButton1Click:Connect(function() openFilter("PICKUP") end)
SellFilterBtn.MouseButton1Click:Connect(function() openFilter("SELL") end)

