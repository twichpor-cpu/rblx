-- PHYSICAL COLLECTION (For Banknote Models)
local function banknotePhysicalTouch(obj)
    if not Running or not obj or not Player.Character then return end
    local root = Player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart", true)
    
    if targetPart then
        local oldCFrame = root.CFrame
        root.CFrame = targetPart.CFrame -- Physical move to the model
        task.wait(0.05) -- Wait for physics engine
        root.CFrame = oldCFrame -- Move back
    end
end

-- STANDARD GHOST TOUCH (For regular Tools)
local function ghostTouch(obj)
    if not Running or not obj then return end
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    
    if root and handle and firetouchinterest then
        firetouchinterest(root, handle, 0)
        task.wait()
        firetouchinterest(root, handle, 1)
    end
end

