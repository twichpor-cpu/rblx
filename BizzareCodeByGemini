-- Helper: FIND PART (Works for both Tools and Models)
local function getTargetPart(obj)
    if obj:IsA("Tool") then
        return obj:FindFirstChild("Handle") or obj:FindFirstChildWhichIsA("BasePart")
    elseif obj:IsA("Model") then
        return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    end
    return nil
end

-- Helper: GHOST TOUCH
local function ghostTouch(obj)
    if not Running or not obj.Parent then return end
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    local handle = getTargetPart(obj)
    if root and handle then
        firetouchinterest(root, handle, 0)
        task.wait()
        firetouchinterest(root, handle, 1)
    end
end

-- Helper: SAFE FORWARD TELEPORT (Anti-Fling)
local function teleportTo(obj)
    if not Running or not obj.Parent then return end
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    local targetPart = getTargetPart(obj)
    
    if root and targetPart then
        root.AssemblyLinearVelocity = Vector3.new(0,0,0)
        root.AssemblyAngularVelocity = Vector3.new(0,0,0)
        root.CFrame = targetPart.CFrame * CFrame.new(0, 3, 0)
    end
end

