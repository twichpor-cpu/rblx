-- MAIN LOOP (DUAL-ZONE + MODEL SUPPORT)
task.spawn(function()
    while Running do
        local trapPart = workspace:FindFirstChild("Part")
        local currentCounts = {}
        local currentTools = {}

        local function scanContainer(container, useSafety)
            if not container then return end
            for _, obj in pairs(container:GetChildren()) do
                if obj:IsA("Tool") or obj:IsA("Model") then
                    if Players:GetPlayerFromCharacter(obj) then continue end 
                    
                    local h = getTargetPart(obj)
                    if h then
                        local isSafe = true
                        if useSafety and trapPart then
                            isSafe = (h.Position - trapPart.Position).Magnitude >= SAFE_DISTANCE
                        end

                        if isSafe then
                            local name = obj.Name
                            if CollectNotes and (name == "Banknote" or name == "troll banknote") then
                                teleportTo(obj)
                                currentCounts[name] = (currentCounts[name] or 0) + 1
                                currentTools[name] = obj
                            elseif PickupFilter[name] then
                                currentCounts[name] = (currentCounts[name] or 0) + 1
                                currentTools[name] = obj
                                if AutoPickup then ghostTouch(obj) end
                            end
                        end
                    end
                end
            end
        end

        scanContainer(workspace:FindFirstChild("Items"), false) 
        scanContainer(workspace, true)

        for name, btn in pairs(TrackerButtons) do
            if not currentCounts[name] then btn:Destroy(); TrackerButtons[name] = nil end
        end
        for name, count in pairs(currentCounts) do
            if not TrackerButtons[name] then
                local b = Instance.new("TextButton", TrackerPage)
                b.Size = UDim2.new(1, 0, 0, 25); b.TextColor3 = Color3.new(1,1,1); b.BackgroundTransparency = 0.9; b.TextXAlignment = Enum.TextXAlignment.Left
                b.MouseButton1Click:Connect(function() 
                    local target = currentTools[name]
                    if target and target.Name:lower():find("banknote") then teleportTo(target) else ghostTouch(target) end 
                end)
                TrackerButtons[name] = b
            end
            TrackerButtons[name].Text = "  " .. name .. " x" .. count
        end
        task.wait(0.1)
    end
end)

-- SELL LOOP
task.spawn(function()
    while Running and task.wait(0.1) do
        if AutoSell and Player.Character then
            local heldTool = Player.Character:FindFirstChildOfClass("Tool")
            if not heldTool then
                local bp = Player:FindFirstChild("Backpack")
                if bp then
                    for _, tool in pairs(bp:GetChildren()) do 
                        if tool:IsA("Tool") and not SellFilter[tool.Name] then 
                            tool.Parent = Player.Character; break 
                        end 
                    end
                end
            end
            local newHeld = Player.Character:FindFirstChildOfClass("Tool")
            if newHeld and not SellFilter[newHeld.Name] then SellRemote:FireServer() end
        end
    end
end)
