-- Combined Tester for Combat, Quest Remotes, and UI
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Remote Paths
local ByteNet = ReplicatedStorage:WaitForChild("ByteNetReliable")
local AcceptQuestRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("AcceptQuest")

-- Configuration
local SETTINGS = {
    MissionName = "Extermination",
    AttackDelay = 0.3,
    CombatBuffer = buffer.fromstring("\x06\x0d\x00CombatVisuals\x01\x02\x00m1\xAB\xAA\xAA>\x05\x00swing"),
    AutoFarmEnabled = false
}

-- Functions
local function performAttack()
    ByteNet:FireServer(SETTINGS.CombatBuffer)
end

-- Method 1: Direct Remote Fire (Cleanest)
local function acceptMissionRemote()
    print("Sending Remote request for mission: " .. SETTINGS.MissionName)
    AcceptQuestRemote:FireServer(SETTINGS.MissionName)
end

-- Method 2: Proximity Prompt Interaction
local function triggerMissionPrompt()
    local prompt = Workspace:FindFirstChild("MissionBoard") 
        and Workspace.MissionBoard:FindFirstChild("Fabric") 
        and Workspace.MissionBoard.Fabric:FindFirstChild("MissionBoardPrompt")
    
    if prompt then
        print("Triggering Mission Board Prompt...")
        -- Using fireproximityprompt or simulate interaction
        fireproximityprompt(prompt, 20) 
    else
        warn("MissionBoardPrompt not found in workspace!")
    end
end

-- Method 3: UI Force-Fire (Simulates clicking the list item)
local function forceFireUIButton()
    local btnPath = LocalPlayer.PlayerGui:FindFirstChild("MissionBoardGui")
        and LocalPlayer.PlayerGui.MissionBoardGui:FindFirstChild("MainFrame")
        and LocalPlayer.PlayerGui.MissionBoardGui.MainFrame:FindFirstChild("MissionList")
        and LocalPlayer.PlayerGui.MissionBoardGui.MainFrame.MissionList:FindFirstChild(SETTINGS.MissionName)
        and LocalPlayer.PlayerGui.MissionBoardGui.MainFrame.MissionList[SETTINGS.MissionName]:FindFirstChild("TextButton")

    if btnPath then
        print("Force-firing UI Button for " .. SETTINGS.MissionName)
        -- Simulates a mouse click on the actual game button
        for _, connection in pairs(getconnections(btnPath.MouseButton1Click)) do
            connection:Fire()
        end
    else
        warn("UI Mission Button not found!")
    end
end

