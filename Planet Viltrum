-----------------------------------------------------------
-- LOGIC
-----------------------------------------------------------

-- 1. Open Game Mission Board
openBoardBtn.MouseButton1Click:Connect(function()
    local missionBoard = LocalPlayer.PlayerGui:FindFirstChild("MissionBoardGui")
    if missionBoard and missionBoard:FindFirstChild("MainFrame") then
        missionBoard.MainFrame.Visible = true
    else
        -- Fallback: If UI isn't loaded, try to force-click the button
        forceFireUIButton()
    end
end)

-- 2. Trigger World Prompt
promptBtn.MouseButton1Click:Connect(function()
    triggerMissionPrompt()
end)

-- 3. Toggle Auto-Farm
toggleFarmBtn.MouseButton1Click:Connect(function()
    SETTINGS.AutoFarmEnabled = not SETTINGS.AutoFarmEnabled
    
    if SETTINGS.AutoFarmEnabled then
        toggleFarmBtn.Text = "Auto-Farm: ON"
        toggleFarmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        
        task.spawn(function()
            while SETTINGS.AutoFarmEnabled do
                -- Sequence: Trigger Prompt -> Accept Remote -> Attack
                triggerMissionPrompt()
                task.wait(0.6) -- Wait for prompt hold time
                acceptMissionRemote()
                task.wait(1)
                
                -- Attack cycle
                for i = 1, 15 do
                    if not SETTINGS.AutoFarmEnabled then break end
                    performAttack()
                    task.wait(SETTINGS.AttackDelay)
                end
                task.wait(1)
            end
        end)
    else
        toggleFarmBtn.Text = "Auto-Farm: OFF"
        toggleFarmBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end
end)

-- 4. Close this Menu
closeBtn.MouseButton1Click:Connect(function()
    SETTINGS.AutoFarmEnabled = false 
    screenGui:Destroy()
end)
