-- Function to find the closest item of a specific name
local function getClosestItem(itemName)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local playerPos = character.HumanoidRootPart.Position
    local closestItem = nil
    local shortestDistance = math.huge
    
    for _, item in ipairs(spawnedToolsFolder:GetChildren()) do
        if item.Name == itemName then
            -- Handle both standard Tools (Handle) and Models/Parts
            local itemPart = item:FindFirstChild("Handle") or item:FindFirstChildOfClass("Part") or item:FindFirstChildOfClass("MeshPart") or item
            if itemPart:IsA("BasePart") then
                local distance = (playerPos - itemPart.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestItem = itemPart
                end
            end
        end
    end
    return closestItem
end

-- Function to refresh the GUI item list
local function refreshList()
    -- Clear current buttons
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    -- Count items
    local itemCounts = {}
    for _, item in ipairs(spawnedToolsFolder:GetChildren()) do
        itemCounts[item.Name] = (itemCounts[item.Name] or 0) + 1
    end
    
    -- Create buttons for each unique item
    for itemName, count in pairs(itemCounts) do
        local ItemButton = Instance.new("TextButton")
        ItemButton.Size = UDim2.new(1, 0, 0, 30)
        ItemButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        ItemButton.BorderSizePixel = 0
        
        -- Display formatting: Name x[Count] if duplicates exist
        if count > 1 then
            ItemButton.Text = itemName .. " x[" .. tostring(count) .. "]"
        else
            ItemButton.Text = itemName
        end
        
        ItemButton.TextColor3 = Color3.fromRGB(200, 200, 200)
        ItemButton.TextSize = 14
        ItemButton.Font = Enum.Font.SourceSans
        ItemButton.Parent = ScrollingFrame
        
        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(0, 4)
        ButtonCorner.Parent = ItemButton
        
        -- Teleport logic on click (Fixed for rotated/upside-down items)
        ItemButton.MouseButton1Click:Connect(function()
            local targetPart = getClosestItem(itemName)
            if targetPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                -- Strips rotation, adds 3 studs strictly UP in world space, and keeps player upright
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0))
            end
        end)
    end
end

-- Initial population
refreshList()

-- Automatically refresh when items are added or removed from the folder
spawnedToolsFolder.ChildAdded:Connect(refreshList)
spawnedToolsFolder.ChildRemoved:Connect(refreshList)
