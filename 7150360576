-- Custom Resizing Engine Logic
local isResizing = false
local dragStartPos = nil
local startHeight = nil

ResizeHandle.InputBegan:Connect(function(input)
    if not isCollapsed and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        isResizing = true
        MainFrame.Draggable = false
        dragStartPos = input.Position.Y
        startHeight = MainFrame.Size.Y.Offset
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local deltaY = input.Position.Y - dragStartPos
        local newHeight = math.max(minHeight, startHeight + deltaY)
        
        local screenY = ScreenGui.AbsoluteSize.Y
        if (MainFrame.AbsolutePosition.Y + newHeight) > screenY then
            newHeight = screenY - MainFrame.AbsolutePosition.Y
        end
        
        expandedHeight = newHeight
        MainFrame.Size = UDim2.new(0, 280, 0, newHeight)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if isResizing then
            isResizing = false
            MainFrame.Draggable = true
        end
    end
end)

-- Tracking Data
local activeButtons = {}
local lastTrackedPosition = Vector3.new(0, 0, 0)

-- Helper function to reset camera smoothly back to the player
local function resetCameraToPlayer()
    currentlyViewedItem = nil
    viewedInstancesList = {}
    currentViewIndex = 1
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            Camera.CameraSubject = humanoid
        end
    end
    
    -- Reset colors of all eye icons back to default
    for _, btn in pairs(activeEyeButtons) do
        btn.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end

-- Compiles all parts associated with a specific tool name sorted by proximity
local function getAllInstancesOfItem(itemName)
    local character = LocalPlayer.Character
    local playerPos = character and character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart.Position or Vector3.new(0,0,0)
    
    local items = {}
    for _, item in ipairs(spawnedToolsFolder:GetChildren()) do
        if item and item.Name and item.Name == itemName and not itemBlacklist[item.Name] then
            local itemPart = item:FindFirstChild("Handle") or item:FindFirstChildOfClass("Part") or item:FindFirstChildOfClass("MeshPart") or item
            if itemPart and itemPart:IsA("BasePart") then
                table.insert(items, {Part = itemPart, Dist = (playerPos - itemPart.Position).Magnitude})
            end
        end
    end
    
    -- Sort instances so index 1 is always the closest one
    table.sort(items, function(a, b) return a.Dist < b.Dist end)
    
    local finalPartsList = {}
    for _, info in ipairs(items) do
        table.insert(finalPartsList, info.Part)
    end
    return finalPartsList
end

local function getClosestItemData(itemName)
    local instances = getAllInstancesOfItem(itemName)
    if #instances > 0 then
        return instances[1], instances[1].Parent and (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (LocalPlayer.Character.HumanoidRootPart.Position - instances[1].Position).Magnitude or math.huge)
    end
    return nil, nil
end

local function updateDistances()
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        lastTrackedPosition = character.HumanoidRootPart.Position
        for itemName, distanceLabel in pairs(activeButtons) do
            if distanceLabel and distanceLabel.Parent then
                local _, distance = getClosestItemData(itemName)
                if distance and distance ~= math.huge then
                    distanceLabel.Text = math.floor(distance) .. " studs"
                else
                    distanceLabel.Text = "--- studs"
                end
            end
        end
    end
end

local function refreshList()
    activeButtons = {}
    activeEyeButtons = {}
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local itemCounts = {}
    for _, item in ipairs(spawnedToolsFolder:GetChildren()) do
        if item and item.Name and not itemBlacklist[item.Name] then
            itemCounts[item.Name] = (itemCounts[item.Name] or 0) + 1
        end
    end
    
    local sortedItems = {}
    for itemName, count in pairs(itemCounts) do
        table.insert(sortedItems, {Name = itemName, Count = count})
    end
    
    if currentSortMode == "Count" then
        table.sort(sortedItems, function(a, b)
            return a.Count > b.Count
        end)
    elseif currentSortMode == "Alphabetical" then
        table.sort(sortedItems, function(a, b)
            return a.Name:lower() < b.Name:lower()
        end)
    end
    
    for index, data in ipairs(sortedItems) do
        local ItemButton = Instance.new("TextButton")
        ItemButton.Size = UDim2.new(1, 0, 0, 35)
        ItemButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        ItemButton.BorderSizePixel = 0
        ItemButton.Text = ""
        ItemButton.LayoutOrder = index
        ItemButton.Parent = ScrollingFrame
        
        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(0, 4)
        ButtonCorner.Parent = ItemButton
        
        local displayName = (data.Count > 1) and (data.Name .. " x" .. data.Count) or data.Name
        
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(0.5, 0, 1, 0) -- Scaled down slightly to leave space for eye button
        NameLabel.Position = UDim2.new(0, 10, 0, 0)
        NameLabel.BackgroundTransparency = 1
        NameLabel.TextXAlignment = Enum.TextXAlignment.Left
        NameLabel.Text = displayName
        NameLabel.TextColor3 = Color3.fromRGB(225, 225, 225)
        NameLabel.Font = Enum.Font.SourceSansSemibold
        NameLabel.TextSize = 14
        NameLabel.Parent = ItemButton
        
        local DistanceLabel = Instance.new("TextLabel")
        DistanceLabel.Size = UDim2.new(0.25, 0, 1, 0)
        DistanceLabel.Position = UDim2.new(0.55, 0, 0, 0)
        DistanceLabel.BackgroundTransparency = 1
        DistanceLabel.TextXAlignment = Enum.TextXAlignment.Right
        DistanceLabel.Text = "--- studs"
        DistanceLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        DistanceLabel.Font = Enum.Font.SourceSans
        DistanceLabel.TextSize = 13
        DistanceLabel.Parent = ItemButton
        
        -- Eye View/Spectate Button
        local EyeButton = Instance.new("TextButton")
        EyeButton.Size = UDim2.new(0, 30, 0, 30)
        EyeButton.Position = UDim2.new(1, -35, 0, 2)
        EyeButton.BackgroundTransparency = 1
        EyeButton.Text = "👁"
        EyeButton.TextColor3 = (currentlyViewedItem == data.Name) and Color3.fromRGB(120, 200, 255) or Color3.fromRGB(150, 150, 150)
        EyeButton.TextSize = 15
        EyeButton.Font = Enum.Font.SourceSansBold
        EyeButton.Parent = ItemButton
        
        activeButtons[data.Name] = DistanceLabel
        activeEyeButtons[data.Name] = EyeButton
        
        -- Teleport functionality on main button row left click
        ItemButton.MouseButton1Click:Connect(function()
            local targetPart, _ = getClosestItemData(data.Name)
            if targetPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0))
                task.wait(0.05)
                updateDistances()
            end
        end)
        
        -- View Button Left Click (Inspect) and Right Click (Cycle copies) Handler
        EyeButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                -- Left Click Behavior
                if currentlyViewedItem == data.Name then
                    -- Left clicking the active item closes the view menu
                    resetCameraToPlayer()
                else
                    -- Left clicking a new item closes old view and opens this one
                    resetCameraToPlayer()
                    viewedInstancesList = getAllInstancesOfItem(data.Name)
                    
                    if #viewedInstancesList > 0 then
                        currentlyViewedItem = data.Name
                        currentViewIndex = 1
                        Camera.CameraSubject = viewedInstancesList[1]
                        EyeButton.TextColor3 = Color3.fromRGB(120, 200, 255) -- Highlight active eye
                    end
                end
            elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                -- Right Click Behavior (Only handles if it's already the active viewed item type)
                if currentlyViewedItem == data.Name then
                    viewedInstancesList = getAllInstancesOfItem(data.Name) -- Refresh positions in case items were grabbed
                    if #viewedInstancesList > 1 then
                        currentViewIndex = currentViewIndex + 1
                        if currentViewIndex > #viewedInstancesList then
                            currentViewIndex = 1
                        end
                        Camera.CameraSubject = viewedInstancesList[currentViewIndex]
                    end
                end
            end
        end)
    end
    updateDistances()
end

