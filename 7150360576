-- Window Control Mechanics
CloseButton.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

CollapseButton.MouseButton1Click:Connect(function()
    isCollapsed = not isCollapsed
    
    local targetHeight = isCollapsed and collapsedHeight or expandedHeight
    local targetArrow = isCollapsed and "◀" or "▼"
    
    CollapseButton.Text = targetArrow
    
    -- Smoothly roll up/down using Tweens
    local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local sizeTween = TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(0, 280, 0, targetHeight)})
    sizeTween:Play()
end)

-- Global Data Tracker setup
local activeButtons = {}
local lastTrackedPosition = Vector3.new(0, 0, 0)

local function getClosestItemData(itemName)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil, nil end
    
    local playerPos = character.HumanoidRootPart.Position
    local shortestDistance = math.huge
    local closestPart = nil
    
    for _, item in ipairs(spawnedToolsFolder:GetChildren()) do
        if item.Name == itemName then
            local itemPart = item:FindFirstChild("Handle") or item:FindFirstChildOfClass("Part") or item:FindFirstChildOfClass("MeshPart") or item
            if itemPart:IsA("BasePart") then
                local distance = (playerPos - itemPart.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestPart = itemPart
                end
            end
        end
    end
    return closestPart, shortestDistance
end

local function refreshList()
    activeButtons = {}
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local itemCounts = {}
    for _, item in ipairs(spawnedToolsFolder:GetChildren()) do
        itemCounts[item.Name] = (itemCounts[item.Name] or 0) + 1
    end
    
    for itemName, count in pairs(itemCounts) do
        local ItemButton = Instance.new("TextButton")
        ItemButton.Size = UDim2.new(1, 0, 0, 35)
        ItemButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        ItemButton.BorderSizePixel = 0
        ItemButton.Text = ""
        ItemButton.Parent = ScrollingFrame
        
        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(0, 4)
        ButtonCorner.Parent = ItemButton
        
        local NameLabel = Instance.new("TextLabel")
        NameLabel.Size = UDim2.new(0.65, 0, 1, 0)
        NameLabel.Position = UDim2.new(0, 10, 0, 0)
        NameLabel.BackgroundTransparency = 1
        NameLabel.TextXAlignment = Enum.TextXAlignment.Left
        NameLabel.Text = (count > 1) and (itemName .. " x[" .. count .. "]") or itemName
        NameLabel.TextColor3 = Color3.fromRGB(225, 225, 225)
        NameLabel.Font = Enum.Font.SourceSansSemibold
        NameLabel.TextSize = 14
        NameLabel.Parent = ItemButton
        
        local DistanceLabel = Instance.new("TextLabel")
        DistanceLabel.Size = UDim2.new(0.3, 0, 1, 0)
        DistanceLabel.Position = UDim2.new(0.7, -10, 0, 0)
        DistanceLabel.BackgroundTransparency = 1
        DistanceLabel.TextXAlignment = Enum.TextXAlignment.Right
        DistanceLabel.Text = "--- studs"
        DistanceLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        DistanceLabel.Font = Enum.Font.SourceSans
        DistanceLabel.TextSize = 13
        DistanceLabel.Parent = ItemButton
        
        activeButtons[itemName] = DistanceLabel
        
        ItemButton.MouseButton1Click:Connect(function()
            local targetPart, _ = getClosestItemData(itemName)
            if targetPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0))
                lastTrackedPosition = Vector3.new(0,0,0) -- Force distance recalculation post-teleport
            end
        end)
    end
end

refreshList()
spawnedToolsFolder.ChildAdded:Connect(refreshList)
spawnedToolsFolder.ChildRemoved:Connect(refreshList)

-- Dynamic Distance Loop (Stays optimized even when rolled up)
task.spawn(function()
    while true do
        task.wait(0.5)
        
        -- Don't calculate or waste processing power if window is currently rolled up
        if not isCollapsed then
            local character = LocalPlayer.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local currentPos = character.HumanoidRootPart.Position
                local deltaDistance = (currentPos - lastTrackedPosition).Magnitude
                
                if deltaDistance > 15 then
                    lastTrackedPosition = currentPos
                    for itemName, distanceLabel in pairs(activeButtons) do
                        if distanceLabel and distanceLabel.Parent then
                            local _, distance = getClosestItemData(itemName)
                            if distance and distance ~= math.huge then
                                distanceLabel.Text = math.floor(distance) .. " studs"
                            else
                                distanceLabel.Text = "--- studs"
                            end
                        end
                    end
                end
            end
        end
    end
end)
