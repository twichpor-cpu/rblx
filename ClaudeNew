-- ================================================================
--  IY-STYLE TELEPORT
-- ================================================================
local function iyTeleport(pos, offsetY)
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            p.AssemblyLinearVelocity  = Vector3.zero
            p.AssemblyAngularVelocity = Vector3.zero
        end
    end
    local y = offsetY or TP_OFFSETS.default
    hrp.CFrame = CFrame.new(pos + Vector3.new(0, y, 0))
end

-- ================================================================
--  ZONE CHECKS
-- ================================================================
local function inBox(pos, centre, half)
    local r = pos - centre
    return math.abs(r.X)<=half.X and math.abs(r.Y)<=half.Y and math.abs(r.Z)<=half.Z
end

local function inSpawnAreas(pos)
    local areas = Workspace:FindFirstChild("ItemSpawnAreas")
    if not areas then return false end
    for _, part in ipairs(areas:GetDescendants()) do
        if part:IsA("BasePart") then
            local lpos = part.CFrame:PointToObjectSpace(pos)
            local h    = part.Size / 2
            if math.abs(lpos.X)<=h.X and math.abs(lpos.Y)<=h.Y and math.abs(lpos.Z)<=h.Z then
                return true
            end
        end
    end
    return false
end

local function hasSafeBlocks(item)
    -- secondary spawn: item is safe if there are BaseParts nearby (not the item itself)
    local ref = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
    if not ref then return false end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj ~= ref and not obj:IsDescendantOf(item) then
            if (obj.Position - ref.Position).Magnitude < 20 then
                return true
            end
        end
    end
    return false
end

local function isInZone(pos)
    return inBox(pos, MAIN_BOX_POS, MAIN_BOX_HALF) or inSpawnAreas(pos)
end

-- ================================================================
--  TOOL SCAN
--  Returns { [name] = { count=N, parts={BasePart,...} } }
-- ================================================================
local function scanTools()
    local result = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") then
            local owned = false
            local p = obj.Parent
            while p and p ~= Workspace do
                if p:IsA("Backpack") or (p:IsA("Model") and p:FindFirstChildOfClass("Humanoid")) then
                    owned = true; break
                end
                p = p.Parent
            end
            if not owned then
                local ref = obj:FindFirstChild("Handle") or obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if ref then
                    local pos = ref.Position
                    local inMain = isInZone(pos)
                    -- secondary spawn check: not in main zone but has safe blocks nearby
                    local inSecondary = (not inMain) and hasSafeBlocks(obj)
                    if inMain or inSecondary then
                        local n = obj.Name
                        if not result[n] then result[n] = {count=0, parts={}} end
                        result[n].count += 1
                        table.insert(result[n].parts, ref)
                    end
                end
            end
        end
    end
    return result
end

