local function fireSell()
    local remote = ReplicatedStorage
        :FindFirstChild("BismalqStuff")
        and ReplicatedStorage.BismalqStuff
        :FindFirstChild("Remotes")
        and ReplicatedStorage.BismalqStuff.Remotes
        :FindFirstChild("Sell")
    if remote then remote:FireServer() end
end

local function equipItem(toolName)
    -- try backpack first, then character
    local bp = lp:FindFirstChild("Backpack")
    if bp then
        local tool = bp:FindFirstChild(toolName)
        if tool then
            lp.Character.Humanoid:EquipTool(tool)
            return true
        end
    end
    return false
end

-- ================================================================
--  COLLECT NOTES
-- ================================================================
local function teleportToNote()
    if not collectNotesOn then return end
    local container = Workspace:FindFirstChild("Banknote")
    if not container then return end
    local ref = container:IsA("BasePart") and container
             or container:FindFirstChildWhichIsA("BasePart", true)
    if ref then iyTeleport(ref.Position, TP_OFFSETS.Banknote) end
end

-- ================================================================
--  SERVER TIME / SPAWN TIMER
-- ================================================================
local function getServerTime()
    pcall(function()
        local timeLabel = pgui:FindFirstChild("UIs")
            and pgui.UIs:FindFirstChild("VersionUI")
            and pgui.UIs.VersionUI:FindFirstChild("Time")
        if timeLabel then
            return tonumber(timeLabel.Text) or os.clock()
        end
    end)
    return os.clock()
end

local lastSpawnTime = getServerTime()
local nextSpawnIn   = SPAWN_CYCLE

local function updateSpawnTimer()
    local now  = getServerTime()
    local diff = now - lastSpawnTime
    nextSpawnIn = math.max(0, SPAWN_CYCLE - (diff % SPAWN_CYCLE))
end

