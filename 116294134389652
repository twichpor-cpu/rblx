--// 1. Auto Bismuth Logic Loop
task.spawn(function()
    while task.wait(0.1) do
        if FarmEnabled then
            local character = LocalPlayer.Character
            local torso = character and (character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"))
            local itemsFolder = Workspace:FindFirstChild("Items")
            
            if torso and itemsFolder then
                for _, item in ipairs(itemsFolder:GetChildren()) do
                    if item:IsA("BasePart") and item:FindFirstChildOfClass("TouchTransmitter") then
                        item.CFrame = torso.CFrame
                    elseif item:IsA("Model") then
                        for _, subPart in ipairs(item:GetDescendants()) do
                            if subPart:IsA("BasePart") and subPart:FindFirstChildOfClass("TouchTransmitter") then
                                subPart.CFrame = torso.CFrame
                            end
                        end
                    end
                end
            end
        end
    end
end)

--// 2. Auto Stage Reward Logic Loop
task.spawn(function()
    while true do
        if FarmEnabled then
            local character = LocalPlayer.Character
            local torso = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"))
            local originalCFrame = torso and torso.CFrame
            
            for i = 1, 25 do
                if not FarmEnabled then break end
                
                character = LocalPlayer.Character
                torso = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"))
                
                if torso then
                    local buttonName = "StageButton" .. i
                    local buttonInstance = Workspace:FindFirstChild(buttonName, true)
                    
                    if buttonInstance then
                        local prompt = buttonInstance:FindFirstChildOfClass("ProximityPrompt") or buttonInstance:FindFirstChild("ProximityPrompt", true)
                        
                        if prompt then
                            local buttonPart = prompt.Parent
                            if buttonPart and buttonPart:IsA("BasePart") then
                                torso.CFrame = buttonPart.CFrame + Vector3.new(0, 3, 0)
                                task.wait(0.15)
                                
                                if fireproximityprompt then
                                    fireproximityprompt(prompt, 1)
                                else
                                    prompt:InputHoldBegin()
                                    task.wait(prompt.HoldDuration + 0.05)
                                    prompt:InputHoldEnd()
                                end
                                task.wait(0.1)
                            end
                        end
                    end
                end
            end
            
            if FarmEnabled and torso and originalCFrame then
                torso.CFrame = originalCFrame
            end
            task.wait(300.1)
        else
            task.wait(1)
        end
    end
end)

--// 3. Auto Astral Chunk Logic Loop
task.spawn(function()
    while task.wait(0.1) do
        if AstralEnabled then
            local character = LocalPlayer.Character
            local torso = character and (character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"))
            
            if torso then
                for _, item in ipairs(Workspace:GetChildren()) do
                    if item.Name == "AstralChunk" or string.match(item.Name, "AstralChunk") then
                        if item:IsA("BasePart") then
                            item.CFrame = torso.CFrame
                        elseif item:IsA("Model") then
                            local targetPart = item.PrimaryPart or item:FindFirstChildOfClass("BasePart")
                            if targetPart then
                                targetPart.CFrame = torso.CFrame
                            else
                                for _, subPart in ipairs(item:GetDescendants()) do
                                    if subPart:IsA("BasePart") then
                                        subPart.CFrame = torso.CFrame
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

--// 4. Auto Mining Logic Loop
task.spawn(function()
    local MineRockEvent = ReplicatedStorage:WaitForChild("MineRock", 10)
    
    while task.wait(0.1) do
        if MiningEnabled then
            local character = LocalPlayer.Character
            local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")
            
            if humanoidRootPart then
                local function manipulatePart(partInstance)
                    if not partInstance then return end
                    
                    if partInstance:IsA("BasePart") then
                        partInstance.CFrame = humanoidRootPart.CFrame
                        partInstance.CanCollide = false
                        partInstance.Transparency = 1
                    elseif partInstance:IsA("Model") then
                        partInstance:PivotTo(humanoidRootPart.CFrame)
                        for _, desc in ipairs(partInstance:GetDescendants()) do
                            if desc:IsA("BasePart") then
                                desc.CanCollide = false
                                desc.Transparency = 1
                            end
                        end
                    end
                end
                
                -- 1. Manipulate Mining Zone (workspace.Cave.MiningZone)
                local cave = Workspace:FindFirstChild("Cave")
                local miningZone = cave and cave:FindFirstChild("MiningZone") or Workspace:FindFirstChild("MiningZone", true)
                if miningZone then
                    manipulatePart(miningZone)
                end

                -- 2. Find, Manipulate, and Fire Remote on the personal player Ore (workspace.Cave.Ore_UserID)
                if cave and MineRockEvent then
                    local playerOreName = "Ore_" .. UserId
                    local playerOre = cave:FindFirstChild(playerOreName)
                    
                    if playerOre then
                        manipulatePart(playerOre)
                        MineRockEvent:FireServer(playerOre)
                    end
                end
            end
        end
    end
end)

--// 5. Auto Collect Diamond Logic Loop (Fires every 15 seconds)
