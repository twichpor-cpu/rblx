-- MENU TOGGLE WITH BULK ACTIONS
local function toggleSide(mode)
    if CurrentMenu == mode then 
        SidePanel.Visible = false; CurrentMenu = nil
    else
        SidePanel.Visible = true; CurrentMenu = mode
        for _, v in pairs(SideScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        for _, v in pairs(BulkContainer:GetChildren()) do v:Destroy() end
        
        if mode == "ABILITY" then
            BulkContainer.Visible = true
            SideScroll.Position = UDim2.new(0, 2, 0, 35)
            SideScroll.Size = UDim2.new(1, -4, 1, -40)
            
            local function bulkSet(val)
                for _, key in pairs(AbilityKeys) do ActiveAbilities[key] = val end
                toggleSide("ABILITY") -- Refresh display
                toggleSide("ABILITY")
            end

            local allBtn = Instance.new("TextButton", BulkContainer); allBtn.Size = UDim2.new(0.5, 0, 1, 0); allBtn.Text = "ALL"; allBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 40); allBtn.TextColor3 = Color3.new(1,1,1)
            local noneBtn = Instance.new("TextButton", BulkContainer); noneBtn.Size = UDim2.new(0.5, 0, 1, 0); noneBtn.Position = UDim2.new(0.5, 0, 0, 0); noneBtn.Text = "NONE"; noneBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 40); noneBtn.TextColor3 = Color3.new(1,1,1)
            
            allBtn.MouseButton1Click:Connect(function() bulkSet(true) end)
            noneBtn.MouseButton1Click:Connect(function() bulkSet(false) end)

            for _, key in pairs(AbilityKeys) do
                local b = Instance.new("TextButton", SideScroll); b.Size = UDim2.new(1, 0, 0, 30); b.Font = Enum.Font.Code; b.TextColor3 = Color3.new(1,1,1)
                local function up() b.BackgroundColor3 = ActiveAbilities[key] and Color3.fromRGB(100, 80, 20) or Color3.fromRGB(40, 40, 40); b.Text = "Use ["..key.."]" end
                b.MouseButton1Click:Connect(function() ActiveAbilities[key] = not ActiveAbilities[key]; up() end); up()
            end
        else
            BulkContainer.Visible = false
            SideScroll.Position = UDim2.new(0, 2, 0, 5)
            SideScroll.Size = UDim2.new(1, -4, 1, -10)
            for _, name in pairs(TargetList) do
                local b = Instance.new("TextButton", SideScroll); b.Size = UDim2.new(1, 0, 0, 30); b.Font = Enum.Font.Code; b.TextColor3 = Color3.new(1,1,1)
                local function up() b.BackgroundColor3 = SelectedNPCs[name] and Color3.fromRGB(40, 100, 40) or Color3.fromRGB(60, 20, 20); b.Text = name end
                b.MouseButton1Click:Connect(function() SelectedNPCs[name] = not SelectedNPCs[name]; up() end); up()
            end
        end
    end
end

