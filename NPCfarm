CloseBtn.Size = UDim2.new(0, 30, 0, 30); CloseBtn.Position = UDim2.new(1, -30, 0, 0)
CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 40); CloseBtn.Text = "X"; CloseBtn.TextColor3 = Color3.new(1,1,1); CloseBtn.Font = Enum.Font.Code
CloseBtn.MouseButton1Click:Connect(StopEverything)

-- Side Panel / UI Logic (Abbreviated for space, remains same as V5)
local SidePanel = Instance.new("Frame", MainFrame)
SidePanel.Size = UDim2.new(0, 180, 1, 0); SidePanel.Position = UDim2.new(1, 5, 0, 0); SidePanel.BackgroundColor3 = Color3.fromRGB(20, 20, 20); SidePanel.Visible = false; SidePanel.BorderSizePixel = 0
local SideHeader = Instance.new("Frame", SidePanel); SideHeader.Size = UDim2.new(1, 0, 0, 30); SideHeader.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
