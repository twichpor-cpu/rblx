-- LOGIC HELPERS
local function isTarget(name)
    for target, active in pairs(SelectedNPCs) do if active and string.find(name, target) then return true end end
    return false
end

local function isStandOut()
    local s = workspace:FindFirstChild("Entities") and workspace.Entities:FindFirstChild(Player.Name) and workspace.Entities[Player.Name]:FindFirstChild("Stand")
    if s then for _, p in pairs(s:GetDescendants()) do if p:IsA("BasePart") and p.Transparency < 1 then return true end end end
    return false
end

local function ghostTouch(tool)
    if not Running or not tool.Parent then return end
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildWhichIsA("BasePart")
    if root and handle then
        firetouchinterest(root, handle, 0); task.wait(); firetouchinterest(root, handle, 1)
    end
end

-- ATTACK LOOP
task.spawn(function()
    while Running do
        if Farming and Player.Character then
            local root = Player.Character:FindFirstChild("HumanoidRootPart")
            local target = nil
            if workspace:FindFirstChild("Entities") then
                for _, npc in pairs(workspace.Entities:GetChildren()) do
                    if isTarget(npc.Name) and npc:FindFirstChild("HumanoidRootPart") and npc:FindFirstChild("Dead") and npc.Dead.Value == false then
                        target = npc.HumanoidRootPart; break
                    end
                end
            end
            if target and root then
                if not isStandOut() then
                    VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game); task.wait(0.1); VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game); task.wait(1)
                end
                if (root.Position - target.Position).Magnitude <= MaxAttackRange then
                    for key, active in pairs(ActiveAbilities) do
                        if not Farming or not Running then break end
                        if active then
                            VIM:SendKeyEvent(true, Enum.KeyCode[key], false, game)
                            task.wait(key == "E" and 1.5 or 0.1)
                            VIM:SendKeyEvent(false, Enum.KeyCode[key], false, game); task.wait(0.2)
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

-- MOVEMENT LOOP
HeartbeatConn = RunService.Heartbeat:Connect(function()
    if not Running or not Farming or not Player.Character then return end
    local root = Player.Character:FindFirstChild("HumanoidRootPart")
    local entities = workspace:FindFirstChild("Entities")
    if not root or not entities then return end

    local found = false
    for _, npc in pairs(entities:GetChildren()) do
        if isTarget(npc.Name) and npc:FindFirstChild("Dead") and npc.Dead.Value == false then
            local nRoot = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Torso")
            if nRoot then
                found = true; LastBossPosition = nRoot.CFrame
                for _, p in pairs(Player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                root.CFrame = CFrame.new(nRoot.Position - Vector3.new(0, FarmDistance, 0)) * CFrame.Angles(math.rad(90), 0, 0)
                break
            end
        end
    end

    if not found then
        for _, p in pairs(Player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true end end
        local items = workspace:FindFirstChild("Items")
        if items then for _, item in pairs(items:GetChildren()) do ghostTouch(item) end end
        if LastBossPosition then
            repairPhysics(root)
            root.CFrame = CFrame.new(LastBossPosition.Position + Vector3.new(0, 3, 0))
            LastBossPosition = nil
        end
    end
end)
