local SideClose = Instance.new("TextButton", SideHeader); SideClose.Size = UDim2.new(0, 30, 0, 30); SideClose.Position = UDim2.new(1, -30, 0, 0); SideClose.BackgroundColor3 = Color3.fromRGB(60, 60, 60); SideClose.Text = "<"; SideClose.TextColor3 = Color3.new(1,1,1)
SideClose.MouseButton1Click:Connect(function() SidePanel.Visible = false end)
