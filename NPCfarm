Instance.new("UIListLayout", SideScroll).Padding = UDim.new(0, 2)

local MainPage = Instance.new("ScrollingFrame", MainFrame)
MainPage.Size = UDim2.new(1, -10, 1, -45); MainPage.Position = UDim2.new(0, 5, 0, 40); MainPage.BackgroundTransparency = 1; MainPage.AutomaticCanvasSize = Enum.AutomaticSize.Y; MainPage.ScrollBarThickness = 2
Instance.new("UIListLayout", MainPage).Padding = UDim.new(0, 8)

local function createMenuBtn(txt, color)
    local b = Instance.new("TextButton", MainPage); b.Size = UDim2.new(1, 0, 0, 40); b.BackgroundColor3 = color; b.Text = txt; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.Code; b.TextSize = 15; b.BorderSizePixel = 0
    return b
end

local FarmTgl = createMenuBtn("NPC FARM: OFF", Color3.fromRGB(120, 30, 30))
local FilterOpenBtn = createMenuBtn("NPC FILTER >", Color3.fromRGB(50, 50, 50))
local AbilityOpenBtn = createMenuBtn("ABILITY SETUP >", Color3.fromRGB(50, 50, 50))

local function openSide(mode)
    SidePanel.Visible = true
    for _, v in pairs(SideScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    if mode == "NPC" then
        for _, name in pairs(TargetList) do
            local b = Instance.new("TextButton", SideScroll); b.Size = UDim2.new(1, 0, 0, 32); b.Font = Enum.Font.Code; b.TextSize = 13; b.TextColor3 = Color3.new(1,1,1); b.BorderSizePixel = 0
            local function update() b.BackgroundColor3 = SelectedNPCs[name] and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(80, 30, 30); b.Text = name .. (SelectedNPCs[name] and " [ACTIVE]" or " [OFF]") end
            b.MouseButton1Click:Connect(function() SelectedNPCs[name] = not SelectedNPCs[name]; update() end); update()
        end
    elseif mode == "ABILITY" then
        for _, key in pairs(AbilityKeys) do
            local b = Instance.new("TextButton", SideScroll); b.Size = UDim2.new(1, 0, 0, 32); b.Font = Enum.Font.Code; b.TextSize = 13; b.TextColor3 = Color3.new(1,1,1); b.BorderSizePixel = 0
            local function update() b.BackgroundColor3 = ActiveAbilities[key] and Color3.fromRGB(150, 100, 20) or Color3.fromRGB(45, 45, 45); b.Text = "Key: " .. key .. (ActiveAbilities[key] and " [ON]" or " [OFF]") end
            b.MouseButton1Click:Connect(function() ActiveAbilities[key] = not ActiveAbilities[key]; update() end); update()
        end
    end
end

FarmTgl.MouseButton1Click:Connect(function()
    Farming = not Farming
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if Farming then
        if root then HomePosition = root.CFrame end
        FarmTgl.Text = "NPC FARM: ON"; FarmTgl.BackgroundColor3 = Color3.fromRGB(40, 120, 40)
    else
        FarmTgl.Text = "NPC FARM: OFF"; FarmTgl.BackgroundColor3 = Color3.fromRGB(120, 30, 30)
        if char then for _, p in pairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true end end end
        if root and HomePosition then root.CFrame = HomePosition end
    end
end)

FilterOpenBtn.MouseButton1Click:Connect(function() openSide("NPC") end)
AbilityOpenBtn.MouseButton1Click:Connect(function() openSide("ABILITY") end)

-- ATTACK LOOP (Check Running state)
task.spawn(function()
    while Running do
        if Farming then
            local bp = Player:FindFirstChild("Backpack")
            if bp and not bp:FindFirstChild("Standless") then
                for key, active in pairs(ActiveAbilities) do
                    if not Running then break end -- Extra safety
                    if active then
                        local keyCode = Enum.KeyCode[key]
                        if key == "E" then VIM:SendKeyEvent(true, keyCode, false, game); task.wait(1.5); VIM:SendKeyEvent(false, keyCode, false, game)
                        else VIM:SendKeyEvent(true, keyCode, false, game); task.wait(0.1); VIM:SendKeyEvent(false, keyCode, false, game) end
                        task.wait(0.4)
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

-- MOVEMENT LOOP (Assigned to variable for disconnection)
HeartbeatConn = RunService.Heartbeat:Connect(function()
    if not Running then return end
    if not Farming or not Player.Character then return end
    
    local root = Player.Character:FindFirstChild("HumanoidRootPart")
    local entities = workspace:FindFirstChild("Entities")
    if not root or not entities then return end

    local targetFound = false

    for _, npc in pairs(entities:GetChildren()) do
        if npc.Name ~= Player.Name and SelectedNPCs[npc.Name] then
            local dead = npc:FindFirstChild("Dead")
            local npcRoot = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Torso")
            
            if npcRoot and dead and dead.Value == false then
                targetFound = true
                LastBossPosition = npcRoot.CFrame
                for _, p in pairs(Player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
                root.CFrame = CFrame.new(npcRoot.Position - Vector3.new(0, FarmDistance, 0)) * CFrame.Angles(math.rad(90), 0, 0)
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
                break
            end
        end
    end

    if not targetFound then
        for _, p in pairs(Player.Character:GetDescendants()) do 
            if p:IsA("BasePart") then p.CanCollide = true end 
        end
        if LastBossPosition then
            root.CFrame = CFrame.new(LastBossPosition.Position + Vector3.new(0, 3, 0))
            LastBossPosition = nil
        end
    end
end)
