-- TARGETING & ATTACK ENGINE [cite: 5, 7, 8]
local function getTargets()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
    local found = {}
    local maxDist = 12
    if multiTargetActive then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local d = (player.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if d <= maxDist then table.insert(found, player.Character) end
            end
        end
    else
        local closest, dist = nil, maxDist
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local d = (player.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if d < dist then dist = d closest = player.Character end
            end
        end
        if closest then table.insert(found, closest) end
    end
    return found
end

local function performAttack(actionType, val)
    local char = LocalPlayer.Character
    local remote = char and char:FindFirstChild("Fists") and char.Fists:FindFirstChild("fistremote")
    if not remote then return end 
    local count = (actionType == "lmb" and multActive) and (tonumber(MultInput.Text) or 1) or 1
    remote:FireServer(actionType, val)
    if autoHitActive and not isBlocking then
        local targets = getTargets()
        for _, targetChar in pairs(targets) do
            local targetPart = targetChar:FindFirstChild(selectedPart)
            if targetPart then
                for i = 1, count do
                    remote:FireServer("part", targetPart, targetPart.Position, Vector3.new(0, 0, 0))
                end
            end
        end
    end
end

-- ANIMATION LOGIC (Aura Farm [cite: 7])
local function stopAura()
    if currentAnimTrack then
        currentAnimTrack:Stop(0.1)
        currentAnimTrack = nil
    end
end

local function playAura(id)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health > 0 then
        stopAura()
        local anim = Instance.new("Animation")
        anim.AnimationId = id
        currentAnimTrack = hum:LoadAnimation(anim)
        currentAnimTrack.Looped = true
        currentAnimTrack.Priority = Enum.AnimationPriority.Action
        currentAnimTrack:Play()
    end
end

-- MOVEMENT FIX: Forces animation to stop if moving
table.insert(connections, RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum or not auraActive then return end

    -- Check for any movement or jumping [cite: 1]
    local isMoving = hum.MoveDirection.Magnitude > 0
    local isJumping = hum:GetState() == Enum.HumanoidStateType.Jumping or hum:GetState() == Enum.HumanoidStateType.Freefall

    if isMoving or isJumping then
        if currentAnimTrack and currentAnimTrack.IsPlaying then
            stopAura()
        end
    else
        -- Standing still, restart Aura if not playing
        if not currentAnimTrack or not currentAnimTrack.IsPlaying then
            playAura(auraAnimID)
        end
    end
end))

