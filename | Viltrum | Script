-- PARRY COOLDOWN HELPERS (USING ABSOLUTESIZE)
local function getParryState()
    local char = LocalPlayer.Character
    local fists = char and char:FindFirstChild("Fists") or LocalPlayer.Backpack:FindFirstChild("Fists")
    if not fists then return "none" end
    local gui = fists:FindFirstChild("fistgui")
    local lb = gui and gui:FindFirstChild("bars") and gui.bars:FindFirstChild("counterbars") and gui.bars.counterbars:FindFirstChild("behindbar") and gui.bars.counterbars.behindbar:FindFirstChild("loadbar")
    return (lb and lb.AbsoluteSize.Y > 5) and "cooldown" or "ready"
end

local function getBlockState()
    local char = LocalPlayer.Character
    local fists = char and char:FindFirstChild("Fists") or LocalPlayer.Backpack:FindFirstChild("Fists")
    if not fists then return "none" end
    local gui = fists:FindFirstChild("fistgui")
    local bb = gui and gui:FindFirstChild("bars") and gui.bars:FindFirstChild("blockbars") and gui.bars.blockbars:FindFirstChild("behindbar") and gui.bars.blockbars.behindbar:FindFirstChild("loadbar")
    return (bb and bb.AbsoluteSize.Y > 5) and "cooldown" or "ready"
end

-- TARGETING & ATTACK ENGINE
local function getTargets()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return {} end
    local maxDist = 12
    local found = {}
    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char}
    local nearbyParts = workspace:GetPartBoundsInRadius(root.Position, maxDist, params)
    local potentialTargets = {}
    for _, part in ipairs(nearbyParts) do
        local model = part.Parent
        if model and model:FindFirstChild("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
            if not potentialTargets[model] then potentialTargets[model] = model.HumanoidRootPart end
        end
    end
    if multiTargetActive then
        for model, _ in pairs(potentialTargets) do table.insert(found, model) end
    else
        local bestTarget = nil
        local highestDot = -1
        for model, targetRoot in pairs(potentialTargets) do
            local dot = root.CFrame.LookVector:Dot((targetRoot.Position - root.Position).Unit)
            if dot > highestDot then highestDot = dot bestTarget = model end
        end
        if bestTarget then table.insert(found, bestTarget) end
    end
    return found
end

local function performAttack(actionType, val)
    local char = LocalPlayer.Character
    local remote = char and char:FindFirstChild("Fists") and char.Fists:FindFirstChild("fistremote")
    if not remote then return end 
    local isSpecialKey = (actionType == "keypress" and (val == "q" or val == "e"))
    local count = ((actionType == "lmb" or isSpecialKey) and multActive) and (tonumber(MultInput.Text) or 1) or 1
    remote:FireServer(actionType, val)
    if autoHitActive and not isBlocking then
        local targets = getTargets()
        for _, targetChar in pairs(targets) do
            if targetChar and targetChar:FindFirstChild("Humanoid") and targetChar.Humanoid.Health > 0 then
                local finalPartName = (selectedPart == "Ratio") and ((math.random(1, 100) <= hitRatio) and "Head" or "Torso") or selectedPart
                local targetPart = targetChar:FindFirstChild(finalPartName)
                if targetPart then
                    for i = 1, count do remote:FireServer("part", targetPart, targetPart.Position, Vector3.new(0,0,0)) end
                end
            end
        end
    end
end

-- PARRY TRIGGER
local function triggerParry()
    if not autoParryEnabled or tick() - lastParry < PARRY_COOLDOWN then return end
    local char = LocalPlayer.Character
    local fists = char and char:FindFirstChild("Fists") or LocalPlayer.Backpack:FindFirstChild("Fists")
    if not fists then return end
    local remote = fists:FindFirstChild("fistremote")
    if remote then
        if getParryState() == "ready" then
            lastParry = tick()
            remote:FireServer("keypress", "r")
            ParryToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
        elseif getBlockState() == "ready" then
            lastParry = tick()
            remote:FireServer("keypress", "f")
            ParryToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
        end
        task.delay(0.1, function()
            ParryToggleBtn.BackgroundColor3 = autoParryEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
        end)
    end
end

-- AURA HANDLERS
local function stopAura() if currentAnimTrack then currentAnimTrack:Stop(0.2) currentAnimTrack = nil end end
local function playAura(id)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health > 0 then
        stopAura()
        local anim = Instance.new("Animation")
        anim.AnimationId = id
        currentAnimTrack = hum:LoadAnimation(anim)
        currentAnimTrack.Looped = true
        currentAnimTrack.Priority = Enum.AnimationPriority.Action
        currentAnimTrack:Play(0.3)
    end
end

-- MAIN BACKGROUND LOOPS
table.insert(connections, RunService.Heartbeat:Connect(function()
    -- AURA LOGIC
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if hum and root and auraActive then
        local isMoving = root.AssemblyLinearVelocity.Magnitude > 0.5 or hum.MoveDirection.Magnitude > 0 or hum.FloorMaterial == Enum.Material.Air
        if isMoving then if currentAnimTrack then stopAura() end
        else if not currentAnimTrack then playAura(auraAnimID) end end
    end

    -- AUTO PARRY LOGIC
    if not autoParryEnabled or not root then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local eChar = player.Character
            local eRoot = eChar:FindFirstChild("HumanoidRootPart")
            if eRoot and eChar:FindFirstChild("Fists") then
                local offset = eRoot.Position - root.Position
                local dist = offset.Magnitude
                if dist < TRACK_RANGE and math.abs(offset.Y) <= VERTICAL_LIMIT then
                    -- RUSH CHECK
                    if dist < PARRY_RANGE and eRoot.AssemblyLinearVelocity.Magnitude > RUSH_VELOCITY then
                        triggerParry()
                    end
                    -- SNAP CHECK
                    local dot = eRoot.CFrame.LookVector:Dot(-offset.Unit)
                    if dot > LOOK_THRESHOLD then
                        for _, name in pairs({"Right Arm", "Left Arm"}) do
                            local limb = eChar:FindFirstChild(name)
                            if limb then
                                local relCF = eRoot.CFrame:ToObjectSpace(limb.CFrame)
                                local key = player.UserId .. name
                                if lastLimbPositions[key] and (relCF.Position - lastLimbPositions[key].Position).Magnitude > DELTA_THRESHOLD then
                                    if dist < PARRY_RANGE then triggerParry() break end
                                end
                                lastLimbPositions[key] = relCF
                            end
                        end
                    end
                end
            end
        end
    end
end))

