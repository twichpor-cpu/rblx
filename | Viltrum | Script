-- HELPER: UPDATE LOCK
local function updateLock(target)
    if target and target:FindFirstChild("Humanoid") and target.Humanoid.Health > 0 then
        lockedTarget = target
        lockTimer = tick()
    end
end

-- TARGETING LOGIC (ENHANCED WITH NAME KEEPER / LOCK)
local function getTargets()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return {} end

    local maxDist = 17
    local found = {}
    local potentialTargets = {}

    -- Check if existing lock is still valid (Time and Health only)
    if lockedTarget then
        local targetHum = lockedTarget:FindFirstChild("Humanoid")
        
        -- Reset lock ONLY if 5s passed or target died
        if tick() - lockTimer > LOCK_DURATION or (targetHum and targetHum.Health <= 0) then
            lockedTarget = nil
        end
    end

    -- Find parts within radius sphere
    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char}
    
    local nearbyParts = workspace:GetPartBoundsInRadius(root.Position, maxDist, params)

    for _, part in ipairs(nearbyParts) do
        local model = part.Parent
        if model and model:FindFirstChild("Humanoid") and model:FindFirstChild("HumanoidRootPart") then
            if not potentialTargets[model] then
                potentialTargets[model] = model.HumanoidRootPart
            end
        end
    end

    if multiTargetActive then
        for model, _ in pairs(potentialTargets) do table.insert(found, model) end
    else
        -- If we have a valid locked target, stick to them even if they are outside the 12-stud radius
        -- (This allows "Remote-based" persistence even if the radius detection misses them temporarily)
        if lockedTarget then
            table.insert(found, lockedTarget)
        else
            -- Otherwise, find a new target based on LookVector (Front facing)
            local bestTarget = nil
            local highestDot = -1

            for model, targetRoot in pairs(potentialTargets) do
                local directionToTarget = (targetRoot.Position - root.Position).Unit
                local lookDirection = root.CFrame.LookVector
                local dot = lookDirection:Dot(directionToTarget)

                if dot > highestDot then
                    highestDot = dot
                    bestTarget = model
                end
            end
            
            if bestTarget then 
                table.insert(found, bestTarget)
                updateLock(bestTarget) -- Set the lock for 5s
            end
        end
    end

    return found
end

local function stopAura()
    if currentAnimTrack then
        currentAnimTrack:Stop(0.2)
        currentAnimTrack = nil
    end
end

local function playAura(id)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health > 0 then
        stopAura()
        local anim = Instance.new("Animation")
        anim.AnimationId = id
        currentAnimTrack = hum:LoadAnimation(anim)
        currentAnimTrack.Looped = true
        currentAnimTrack.Priority = Enum.AnimationPriority.Action
        currentAnimTrack:Play(0.3)
    end
end

local function performAttack(actionType, val)
    local char = LocalPlayer.Character
    local remote = char and char:FindFirstChild("Fists") and char.Fists:FindFirstChild("fistremote")
    if not remote then return end 

    local isSpecialKey = (actionType == "keypress" and (val == "q" or val == "e"))
    local useMult = (actionType == "lmb" or isSpecialKey) and multActive
    local count = useMult and (tonumber(MultInput.Text) or 1) or 1
    
    remote:FireServer(actionType, val)

    if autoHitActive and not isBlocking then
        local targets = getTargets()
        for _, targetChar in pairs(targets) do
            if targetChar and targetChar:FindFirstChild("Humanoid") and targetChar.Humanoid.Health > 0 then
                -- Refresh the lock timer on every hit
                updateLock(targetChar)

                local finalPartName = selectedPart
                if selectedPart == "Ratio" then
                    local roll = math.random(1, 100)
                    finalPartName = (roll <= hitRatio) and "Head" or "Torso"
                end

                local targetPart = targetChar:FindFirstChild(finalPartName)
                if targetPart then
                    for i = 1, count do
                        remote:FireServer("part", targetPart, targetPart.Position, Vector3.new(0, 0, 0))
                    end
                end
            end
        end
    end
end

-- AUTO-REALIATE / COUNTER-LOCK
local function setupCounterLock()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid")
    
    table.insert(connections, hum.HealthChanged:Connect(function(health)
        local tag = hum:FindFirstChild("creator") or hum:FindFirstChild("Attacker")
        if tag and tag.Value and tag.Value:IsA("Player") and tag.Value.Character then
            updateLock(tag.Value.Character)
        end
    end))
end

-- AURA FARM HEARTBEAT
table.insert(connections, RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if not hum or not root or not auraActive then return end
    
    local isMovingPhysically = root.AssemblyLinearVelocity.Magnitude > 0.5
    local isInputMoving = hum.MoveDirection.Magnitude > 0
    local isAirborne = hum.FloorMaterial == Enum.Material.Air
    
    if isInputMoving or isMovingPhysically or isAirborne then
        if currentAnimTrack and currentAnimTrack.IsPlaying then stopAura() end
    else
        if not currentAnimTrack or not currentAnimTrack.IsPlaying then playAura(auraAnimID) end
    end
end))

