-- Combat Functions
local function getEquippedFists()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("Fists") and char.Fists:FindFirstChild("fistremote")
end

local function getClosestPlayer()
    local closest, dist = nil, 15
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local d = (player.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d closest = player end
        end
    end
    return closest
end

local function fireRemote(remote, ...)
    remote:FireServer(...)
end

local function performAttack(actionType, val)
    local remote = getEquippedFists()
    if not remote then return end 

    -- Filter clicks on UI
    local guiObjects = LocalPlayer.PlayerGui:GetGuiObjectsAtPosition(UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y)
    for _, obj in pairs(guiObjects) do if obj:IsDescendantOf(MainFrame) then return end end

    -- Determine fire count
    local fireCount = (actionType == "lmb" and doubleSwingActive) and 2 or 1

    for i = 1, fireCount do
        -- 1. Send the Action (Swing/Key)
        fireRemote(remote, actionType, val)

        -- 2. Send the Hit (Auto-Hit)
        if autoHitActive and not isBlocking then
            local target = getClosestPlayer()
            if target and target.Character then
                local targetPart = target.Character:FindFirstChild(selectedPart)
                if targetPart then
                    task.wait(0.04) -- Small delay between swing and hit
                    fireRemote(remote, "part", targetPart, targetPart.Position, Vector3.new(0, 0, 0))
                end
            end
        end
        
        if fireCount > 1 and i < fireCount then
            task.wait(0.05) -- Delay between first and second swing
        end
    end
end

-- Input Listeners
table.insert(connections, UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        performAttack("lmb")
    elseif input.KeyCode == Enum.KeyCode.Q or input.KeyCode == Enum.KeyCode.E then
        if tick() - lastSpecial > 0.6 then
            lastSpecial = tick()
            performAttack("keypress", input.KeyCode == Enum.KeyCode.Q and "q" or "e")
        end
    elseif input.KeyCode == Enum.KeyCode.F then
        isBlocking = true
        performAttack("keypress", "f")
    elseif input.KeyCode == Enum.KeyCode.R then
        performAttack("keypress", "r")
    end
end))

table.insert(connections, UserInputService.InputEnded:Connect(function(input, gpe)
    if input.KeyCode == Enum.KeyCode.F then isBlocking = false end
end))
