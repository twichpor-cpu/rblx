-- Combined Tester for Combat, Quest Remotes, and UI
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Remote Paths
local AcceptQuestRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("AcceptQuest")

-- Configuration
local SETTINGS = {
    MissionName = "Extermination"
}

-- UI Helpers (Advanced Force-Fire Logic)
local function forceFire(button)
    if not button then return end 
    pcall(function()
        local events = {"MouseButton1Click", "MouseButton1Down", "Activated"}
        for _, eventName in pairs(events) do
            local signal = button:FindFirstChild(eventName) or button[eventName]
            if signal then
                for _, connection in pairs(getconnections(signal)) do
                    if connection.Function then 
                        task.spawn(connection.Function)
                    elseif connection.Fire then 
                        connection:Fire() 
                    end
                end
            end
        end
    end)
end

-- Helper to find the actual Game Quest Button
local function getGameQuestButton()
    local gui = LocalPlayer.PlayerGui:FindFirstChild("MissionBoardGui")
    local btn = gui and gui:FindFirstChild("MainFrame")
        and gui.MainFrame:FindFirstChild("MissionList")
        and gui.MainFrame.MissionList:FindFirstChild(SETTINGS.MissionName)
        and gui.MainFrame.MissionList[SETTINGS.MissionName]:FindFirstChild("TextButton")
    return btn
end

-- Interaction
local function triggerMissionPrompt()
    local prompt = Workspace:FindFirstChild("MissionBoard") 
        and Workspace.MissionBoard:FindFirstChild("Fabric") 
        and Workspace.MissionBoard.Fabric:FindFirstChild("MissionBoardPrompt")
    
    if prompt then
        fireproximityprompt(prompt, 30) 
        return true
    end
    return false
end

-- Acceptance Logic (Direct from Manual Accept method)
local function executeAcceptance()
    local btn = getGameQuestButton()
    if btn then
        forceFire(btn)
        task.wait(0.05)
        forceFire(btn) -- Double fire for safety
    end
    -- Direct remote call as a fallback
    AcceptQuestRemote:FireServer(SETTINGS.MissionName)
end

