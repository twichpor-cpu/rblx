-- Background Status Sync (Reads directly from Game UI)
task.spawn(function()
    while true do
        if SETTINGS.AutoFarmEnabled then
            local gameBtn = getGameQuestButton()
            if gameBtn then
                local btnText = gameBtn.Text
                if btnText == "Accept" then
                    statusLabel.Text = "Status: Ready!"
                    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                else
                    statusLabel.Text = "Next Quest: " .. btnText
                    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
                end
            else
                statusLabel.Text = "Status: Open Mission Board"
                statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            end
        end
        task.wait(0.5) -- Fast refresh for accurate countdown
    end
end)

-- Manual Accept click
acceptBtn.MouseButton1Click:Connect(function()
    triggerMissionPrompt()
    task.wait(0.6)
    forceFireUIButton()
    acceptMissionRemote()
end)

-- Toggle Auto-Farm
toggleFarmBtn.MouseButton1Click:Connect(function()
    SETTINGS.AutoFarmEnabled = not SETTINGS.AutoFarmEnabled
    
    if SETTINGS.AutoFarmEnabled then
        toggleFarmBtn.Text = "STOP TURBO FARM"
        toggleFarmBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        
        task.spawn(function()
            while SETTINGS.AutoFarmEnabled do
                local gameBtn = getGameQuestButton()
                
                -- Check the actual button text to decide whether to accept
                if gameBtn and gameBtn.Text == "Accept" then
                    triggerMissionPrompt()
                    task.wait(0.7)
                    forceFireUIButton()
                    acceptMissionRemote()
                    task.wait(1) -- Cool down after acceptance
                end
                
                -- Combat Cycle
                for i = 1, 40 do
                    if not SETTINGS.AutoFarmEnabled then break end
                    performAttack()
                    task.wait(SETTINGS.AttackDelay)
                end
                task.wait(0.2)
            end
        end)
    else
        toggleFarmBtn.Text = "START TURBO FARM"
        toggleFarmBtn.BackgroundColor3 = Color3.fromRGB(40, 100, 40)
        statusLabel.Text = "Status: Idle"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    SETTINGS.AutoFarmEnabled = false 
    screenGui:Destroy()
end)
