-- Persistence Logic
local function saveSettings()
    local data = {
        selectedTargets = selectedTargets,
        currentToolType = currentToolType,
        farmDistance = farmDistance
    }
    pcall(function()
        if writefile then
            writefile(SETTINGS_FILE, HttpService:JSONEncode(data))
        end
    end)
end

local function loadSettings()
    pcall(function()
        if readfile and isfile and isfile(SETTINGS_FILE) then
            local data = HttpService:JSONDecode(readfile(SETTINGS_FILE))
            if data.selectedTargets then selectedTargets = data.selectedTargets end
            if data.currentToolType then currentToolType = data.currentToolType end
            if data.farmDistance then farmDistance = data.farmDistance end
        end
    end)
end

