-- Recover Logic: Force clicks the UI to find the button for the weapon
local function attemptWeaponRecovery()
    if not lastKnownWeaponName then return end
    
    StatusLabel.Text = "Bug Detected! Recovering: " .. lastKnownWeaponName
    
    -- 1. Fire category refresh
    if currentToolType == "Physical" then
        forceFire(PhysicalItemsTabBtn)
    else
        forceFire(MagicalItemsTabBtn)
    end
    
    task.wait(0.2)
    
    -- 2. Find the button for the last weapon
    local targetFrame = (currentToolType == "Physical") and PhysicalItemsPath or MagicalItemsPath
    local buttonName = lastKnownWeaponName .. "_Button"
    
    -- Search for the button by name in the children
    for _, child in pairs(targetFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name == "Template" then
            local btn = child:FindFirstChild(buttonName) or child:FindFirstChildOfClass("ImageButton")
            if btn and string.lower(btn.Name) == string.lower(buttonName) then
                forceFire(btn)
                return true
            end
        end
    end
    
    -- Fallback: If not found by template name, just click the last available slot as suggested
    local children = targetFrame:GetChildren()
    if #children >= 2 then
        -- Find the last button among children (indices vary due to layouts)
        local lastValid = nil
        for i = #children, 1, -1 do
            if children[i]:IsA("Frame") and children[i].Name == "Template" then
                lastValid = children[i]:FindFirstChildOfClass("ImageButton")
                if lastValid then break end
            end
        end
        if lastValid then forceFire(lastValid) end
    end
end

-- Farm Logic
local function getBestWeapon()
    local char = player.Character
    if not char then return nil end
    local referencePath = (currentToolType == "Physical") and PhysicalItemsPath or MagicalItemsPath
    
    -- Create a quick map of valid weapons from the UI
    local validNames = {}
    for _, t in pairs(referencePath:GetChildren()) do
        if t:IsA("Frame") and t.Name == "Template" then
            local rb = t:FindFirstChildOfClass("ImageButton")
            if rb then validNames[string.gsub(rb.Name, "_Button", ""):lower()] = true end
        end
    end
    
    -- Check character and backpack
    local foundTool = nil
    for _, tool in pairs(char:GetChildren()) do 
        if tool:IsA("Tool") and validNames[tool.Name:lower()] then 
            foundTool = tool 
            break
        end 
    end
    
    if not foundTool then
        for _, tool in pairs(player.Backpack:GetChildren()) do 
            if tool:IsA("Tool") and validNames[tool.Name:lower()] then 
                foundTool = tool 
                break
            end 
        end
    end
    
    if foundTool then
        lastKnownWeaponName = foundTool.Name -- Update memory
        return foundTool
    end

    -- Trigger Recovery if no tool found and we have a memory of what we should have
    if lastKnownWeaponName and tick() - lastEquipTime > 2 then
        lastEquipTime = tick()
        attemptWeaponRecovery()
    end

    return player.Backpack:FindFirstChildOfClass("Tool") or char:FindFirstChildOfClass("Tool")
end

local function findBestNewTarget()
    local userDmg = getUserDamage()
    local possibleEntries = {}

    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Folder") and (string.find(obj.Name, "Enemies") or obj.Name == "Bosses" or string.find(obj.Name, "Knights") or obj.Name == "Slimes") then
            for _, item in pairs(obj:GetChildren()) do
                if item:IsA("Model") then
                    local matchFound = false
                    for selectedName, _ in pairs(selectedTargets) do
                        if string.find(item.Name:lower(), selectedName:lower()) then matchFound = true; break end
                    end

                    if matchFound then
                        local hum = item:FindFirstChildOfClass("Humanoid")
                        local hrp = item:FindFirstChild("HumanoidRootPart") or item:FindFirstChild("Torso") or item:FindFirstChild("Head")
                        if hum and hrp and hum.Health > 0 then
                            local realHP = item:GetAttribute("BaseHealth") or hum.Health
                            table.insert(possibleEntries, {model = item, hp = realHP})
                        end
                    end
                end
            end
        end
    end

    if #possibleEntries > 0 then
        table.sort(possibleEntries, function(a, b) return a.hp < b.hp end)
        for _, entry in ipairs(possibleEntries) do
            local def = getTargetDefense(entry.model.Name)
            if userDmg > def then return entry.model end
        end
    end
    return nil
end

-- NPC Farm Loop
RunService.Heartbeat:Connect(function()
    if not isAutoFarming then isActivelyFarming = false lockedTarget = nil return end
    
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not hum or hum.Health <= 0 then return end

    if lockedTarget and lockedTarget.Parent then
        local lHum = lockedTarget:FindFirstChildOfClass("Humanoid")
        if not lHum or lHum.Health <= 0 then
            lockedTarget = nil
            isCurrentlyDamaging = false
        else
            local currentHP = lockedTarget:GetAttribute("BaseHealth") or lHum.Health
            if currentHP < lastObservedHP then isCurrentlyDamaging = true end
            lastObservedHP = currentHP
        end
    else
        lockedTarget = nil
        isCurrentlyDamaging = false
    end

    if not isCurrentlyDamaging and (not lockedTarget or tick() - lastScanTime >= scanInterval) then
        lastScanTime = tick()
        local best = findBestNewTarget()
        if best then 
            lockedTarget = best 
            local lHum = lockedTarget:FindFirstChildOfClass("Humanoid")
            lastObservedHP = lockedTarget:GetAttribute("BaseHealth") or (lHum and lHum.Health) or 0
        end
    end

    if lockedTarget then
        local tool = getBestWeapon()
        if not tool then
            isActivelyFarming = false
            StatusLabel.Text = "Status: No Tool (Recovering...)"
            return
        end
        
        if tool.Parent ~= char then
            isActivelyFarming = false
            StatusLabel.Text = "Status: Equipping " .. tool.Name
            if tick() - lastEquipTime > 0.8 then
                lastEquipTime = tick()
                hum:EquipTool(tool)
            end
            return 
        end

        isActivelyFarming = true
        local tHum = lockedTarget:FindFirstChildOfClass("Humanoid")
        local displayHP = lockedTarget:GetAttribute("BaseHealth") or (tHum and tHum.Health) or 0
        StatusLabel.Text = (isCurrentlyDamaging and "DAMAGING: " or "Targeting: ") .. lockedTarget.Name .. " (" .. displayHP .. " HP)"
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local tHRP = lockedTarget:FindFirstChild("HumanoidRootPart") or lockedTarget:FindFirstChild("Torso") or lockedTarget:FindFirstChild("Head")
        
        if hrp and tHRP then
            hrp.CFrame = CFrame.new(tHRP.Position - Vector3.new(0, farmDistance, 0), tHRP.Position)
            hrp.Velocity = Vector3.new(0,0,0)
        end

        if tool.Parent == char then tool:Activate() end
    else
        isActivelyFarming = false
        StatusLabel.Text = "Searching Selected Pool..."
    end
end)

