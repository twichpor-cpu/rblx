local function getBestWeapon()
    local char = player.Character
    if not char then return nil end
    
    local referencePath = (currentToolType == "Physical") and PhysicalItemsPath or MagicalItemsPath
    local validNames = {}
    for _, t in pairs(referencePath:GetChildren()) do
        if t:IsA("Frame") and t.Name == "Template" then
            local rb = t:FindFirstChildOfClass("ImageButton")
            if rb then validNames[string.gsub(rb.Name, "_Button", ""):lower()] = true end
        end
    end

    -- Check Character first (Avoid re-equipping)
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and validNames[tool.Name:lower()] then return tool end
    end
    -- Check Backpack
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") and validNames[tool.Name:lower()] then return tool end
    end
    
    return player.Backpack:FindFirstChildOfClass("Tool") or char:FindFirstChildOfClass("Tool")
end

local function getBestTarget()
    local char = player.Character
    if not char or not selectedTargetName or selectedTargetName == "" then return nil end

    if tick() - lastScanTime >= scanInterval or not cachedTarget or not cachedTarget.Parent then
        lastScanTime = tick()
        local possibleTargets = {}
        local filter = selectedTargetName:lower()
        local userDmg = getUserDamage()
        local targetDef = getTargetDefense()

        for _, obj in pairs(workspace:GetChildren()) do
            if obj:IsA("Folder") and (string.find(obj.Name, "Enemies") or obj.Name == "Bosses" or string.find(obj.Name, "Knights") or obj.Name == "Slimes") then
                for _, item in pairs(obj:GetChildren()) do
                    if item:IsA("Model") and string.find(item.Name:lower(), filter) then
                        local hum = item:FindFirstChildOfClass("Humanoid")
                        local hrp = item:FindFirstChild("HumanoidRootPart") or item:FindFirstChild("Torso") or item:FindFirstChild("Head")
                        
                        if hum and hrp and hum.Health > 0 then
                            local realHP = item:GetAttribute("BaseHealth") or hum.Health
                            table.insert(possibleTargets, {model = item, hp = realHP})
                        end
                    end
                end
            end
        end

        if #possibleTargets > 0 then
            table.sort(possibleTargets, function(a, b) return a.hp < b.hp end)
            
            for _, entry in ipairs(possibleTargets) do
                if userDmg > targetDef then
                    cachedTarget = entry.model
                    return cachedTarget
                else
                    StatusLabel.Text = "Skipped " .. entry.model.Name .. " (Too Tanky)"
                end
            end
            cachedTarget = nil 
        else
            cachedTarget = nil
        end
    end
    
    return cachedTarget
end

-- Main Loop
RunService.Heartbeat:Connect(function()
    if not isAutoFarming then isActivelyFarming = false return end
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not hum or hum.Health <= 0 then return end

    local targetModel = getBestTarget()

    if targetModel then
        local tool = nil
        
        -- TOOL READY CHECK
        if not simpleClickMode then
            tool = getBestWeapon()
            if not tool then
                isActivelyFarming = false
                StatusLabel.Text = "Status: No Tool Found"
                return
            end
            
            -- Strict Equip Logic: If we need a tool, wait until it's in the character
            if tool.Parent ~= char then
                isActivelyFarming = false
                StatusLabel.Text = "Status: Equipping Tool..."
                if tick() - lastEquipTime > 0.8 then -- Slightly longer debounce for post-death
                    lastEquipTime = tick()
                    hum:EquipTool(tool)
                end
                return -- Stop loop here until equipped
            end
        else
            tool = char:FindFirstChildOfClass("Tool")
        end

        -- If we reach here, we either have a tool equipped or are in Simple Click Mode
        isActivelyFarming = true
        local tHum = targetModel:FindFirstChildOfClass("Humanoid")
        local displayHP = targetModel:GetAttribute("BaseHealth") or (tHum and tHum.Health) or 0
        StatusLabel.Text = "Farming: " .. targetModel.Name .. " (HP: " .. displayHP .. ")"
        
        -- Teleport Logic
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local targetHRP = targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Torso") or targetModel:FindFirstChild("Head")
        if hrp and targetHRP then
            hrp.CFrame = CFrame.new(targetHRP.Position - Vector3.new(0, tonumber(DistInput.Text) or 7, 0), targetHRP.Position)
            hrp.Velocity = Vector3.new(0,0,0)
        end

        -- Attack Logic
        if tool and tool.Parent == char then
            tool:Activate()
        end
    else
        isActivelyFarming = false
        StatusLabel.Text = "Searching for valid target..."
    end
end)

