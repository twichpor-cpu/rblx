-- Keep status label updated with the current button state
task.spawn(function()
    while true do
        local gameBtn = getGameQuestButton()
        if gameBtn then
            statusLabel.Text = "State: " .. gameBtn.Text
            if gameBtn.Text == "Accept" then
                statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            else
                statusLabel.TextColor3 = Color3.fromRGB(255, 180, 50)
            end
        else
            statusLabel.Text = "Board Not Found"
            statusLabel.TextColor3 = Color3.fromRGB(200, 50, 50)
        end
        task.wait(0.5)
    end
end)

openMenuBtn.MouseButton1Click:Connect(function()
    triggerMissionPrompt()
end)

acceptBtn.MouseButton1Click:Connect(function()
    executeAcceptance()
end)

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)
