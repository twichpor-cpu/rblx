local function parseValue(str)
    if not str or str == "" then return 0 end
    str = string.gsub(str, "[^%d%.%a%+%-]", "") 
    local num = tonumber(string.match(str, "[%d%.eE%+%-]+")) or 0
    local suffix = string.match(str, "[%a]+$")
    if suffix then
        suffix = suffix:upper()
        if suffix == "K" then num = num * 1e3
        elseif suffix == "M" then num = num * 1e6
        elseif suffix == "B" then num = num * 1e9
        elseif suffix == "T" then num = num * 1e12
        elseif suffix == "QD" then num = num * 1e15
        end
    end
    return num
end

local function getUserDamage()
    local rowName = (currentToolType == "Physical") and "Physical DamageRow" or "Magical DamageRow"
    local row = StatsRows:FindFirstChild(rowName)
    if row and row:FindFirstChild("StatLabel") then
        local baseDmgText = string.match(row.StatLabel.Text, ":%s*([%d%.%a]+)")
        local baseDmg = parseValue(baseDmgText)
        local weaponDmgText = ItemInfo and ItemInfo.Text or "1x"
        local weaponMult = tonumber(string.match(weaponDmgText, "%d+%.?%d*")) or 1
        return baseDmg * weaponMult
    end
    return 0
end

local function getTargetDefense()
    if not selectedTargetName or not DetailsPanel then return 0 end
    local icon = EnemyDisplay:FindFirstChild(selectedTargetName .. "Icon")
    if icon then
        local btn = icon:FindFirstChildOfClass("ImageButton")
        if btn then forceFire(btn) end
    end
    task.wait(0.02)
    local statsFrame = DetailsPanel:FindFirstChild("StatsFrame")
    local defLabel = statsFrame and statsFrame:FindFirstChild("DefenseLabel")
    return defLabel and parseValue(defLabel.Text) or 0
end

