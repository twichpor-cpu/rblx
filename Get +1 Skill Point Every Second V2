    EnemyTabBtn.BackgroundColor3 = (currentTab == "Enemies") and Color3.fromRGB(60, 60, 90) or Color3.fromRGB(45, 45, 45)
    ModTabBtn.BackgroundColor3 = (currentTab == "Modifier") and Color3.fromRGB(60, 60, 90) or Color3.fromRGB(45, 45, 45)

