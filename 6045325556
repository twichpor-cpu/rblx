-- 8. Dragging & Draggability Logic
local dragInput, dragStart, startPos
local dragging = false

local function updateDrag(input)
    local delta = input.Position - dragStart
    local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    
    -- Tween drag for clean physics feel
    TweenService:Create(MainFrame, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = targetPos
    }):Play()
end

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Header.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)

-- 9. Window Resizing Logic
local resizing = false
local resizeStartPos
local resizeStartSize

ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        resizeStartPos = input.Position
        resizeStartSize = MainFrame.AbsoluteSize
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                resizing = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - resizeStartPos
        -- Restrict limits so window doesn't crash to size 0
        local newWidth = math.max(300, resizeStartSize.X + delta.X)
        local newHeight = math.max(220, resizeStartSize.Y + delta.Y)
        
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        updateGridCellSizes()
    end
end)


-- 10. Core Dynamic Car Scanner
-- Explaining why: We will scan "CarShop.Frame" looking for children. 
-- To support the inconsistent naming patterns ("Page1", "page11", "ppage20"), 
-- we convert names to lowercase and match against "page%d+" (page followed by numbers)
-- and "ppage%d+" (ppage followed by numbers).
local function createCarCard(carName, imageId)
    -- Changed from Frame to TextButton to handle user interaction cleanly
    local Card = Instance.new("TextButton")
    Card.Name = carName.."Card"
    Card.BackgroundColor3 = THEME.CardBg
    Card.BorderSizePixel = 0
    Card.Text = "" -- Keep blank to allow custom GUI layout inside
    Card.AutoButtonColor = false -- Disable default dark overlay to maintain custom design
    Card.Parent = ScrollFrame

    local CardCorner = Instance.new("UICorner")
    CardCorner.CornerRadius = UDim.new(0, 6)
    CardCorner.Parent = Card

    -- Shadow-like outline for card
    local CardStroke = Instance.new("UIStroke")
    CardStroke.Color = THEME.Border
    CardStroke.Thickness = 1
    CardStroke.Parent = Card

    -- Image Box
    local CarImage = Instance.new("ImageLabel")
    CarImage.Name = "CarImage"
    CarImage.Size = UDim2.new(1, -12, 0.7, -6)
    CarImage.Position = UDim2.new(0, 6, 0, 6)
    CarImage.BackgroundTransparency = 1
    CarImage.Image = imageId
    CarImage.ScaleType = Enum.ScaleType.Fit
    CarImage.Parent = Card

    -- Name Plate Label
    local CarLabel = Instance.new("TextLabel")
    CarLabel.Name = "CarLabel"
    CarLabel.Size = UDim2.new(1, -12, 0.3, -6)
    CarLabel.Position = UDim2.new(0, 6, 0.7, 4)
    CarLabel.BackgroundTransparency = 1
    CarLabel.TextColor3 = THEME.Text
    CarLabel.Font = Enum.Font.GothamBold
    CarLabel.TextSize = 12
    CarLabel.TextXAlignment = Enum.TextXAlignment.Center
    -- Capitalize first letter of car names nicely
    CarLabel.Text = carName:sub(1,1):upper() .. carName:sub(2):lower()
    CarLabel.Parent = Card

    -- Hover effect animations
    Card.MouseEnter:Connect(function()
        TweenService:Create(CardStroke, TweenInfo.new(0.15), {Color = THEME.Accent}):Play()
    end)
    Card.MouseLeave:Connect(function()
        TweenService:Create(CardStroke, TweenInfo.new(0.15), {Color = THEME.Border}):Play()
    end)

    -- Interaction: Trigger Despawn and Spawn events sequentially on click
    Card.MouseButton1Click:Connect(function()
        -- 1. Despawn any vehicle currently spawned by the user
        local DespawnEvent = ReplicatedStorage:FindFirstChild("DespawnCar")
        if DespawnEvent and DespawnEvent:IsA("RemoteEvent") then
            DespawnEvent:FireServer(nil)
        else
            warn("Custom Car Shop UI: 'DespawnCar' RemoteEvent not found in ReplicatedStorage!")
        end
        
        -- Brief safety wait to allow the despawn event to complete processing
        task.wait(0.1)
        
        -- 2. Spawn the selected vehicle (passes the exact string name e.g. "clio")
        local SpawnEvent = ReplicatedStorage:FindFirstChild("SpawnCar")
        if SpawnEvent and SpawnEvent:IsA("RemoteEvent") then
            SpawnEvent:FireServer(carName)
        else
            warn("Custom Car Shop UI: 'SpawnCar' RemoteEvent not found in ReplicatedStorage!")
        end
    end)
end

local function scanCarShopPages()
    local CarShop = PlayerGui:WaitForChild("CarShop", 5)
    if not CarShop then
        warn("Custom Car Shop UI: Could not locate 'PlayerGui.CarShop'")
        return
    end

    local Frame = CarShop:WaitForChild("Frame", 5)
    if not Frame then
        warn("Custom Car Shop UI: Could not locate 'PlayerGui.CarShop.Frame'")
        return
    end

    -- Clear previous items
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then
            child:Destroy()
        end
    end

    local foundCars = 0

    -- Iterate through Frame to find all Page objects dynamically
    for _, page in ipairs(Frame:GetChildren()) do
        local lowerName = page.Name:lower()
        -- Robust checking pattern matches: "page1" through "page19", "ppage20" onwards, etc.
        if lowerName:match("^page%d+$") or lowerName:match("^ppage%d+$") then
            local carsFolder = page:FindFirstChild("cars")
            if carsFolder then
                for _, carLabel in ipairs(carsFolder:GetChildren()) do
                    if carLabel:IsA("ImageLabel") then
                        -- Name (e.g., "clio", "megane")
                        local carName = carLabel.Name
                        -- Image Asset URL
                        local imageId = carLabel.Image
                        
                        -- Generate card inside our custom view list
                        createCarCard(carName, imageId)
                        foundCars = foundCars + 1
                    end
                end
            end
        end
    end

    -- Update Layout Grid parameters once
    updateGridCellSizes()

    if foundCars == 0 then
         -- Fallback display label in case no images were found
         local TempText = Instance.new("TextLabel")
         TempText.Size = UDim2.new(1, 0, 1, 0)
         TempText.BackgroundTransparency = 1
         TempText.Text = "No vehicles found in shop metadata!"
         TempText.TextColor3 = THEME.TextMuted
         TempText.Font = Enum.Font.Gotham
         TempText.TextSize = 14
         TempText.Parent = ScrollFrame
    end
end

-- Initialize page scanner
task.spawn(scanCarShopPages)
