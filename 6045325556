-- Grid Layout (Autosizes elements depending on container scale)
local UIGridLayout = Instance.new("UIGridLayout")
UIGridLayout.Parent = ScrollFrame
UIGridLayout.SortOrder = Enum.SortOrder.LayoutOrder
UIGridLayout.CellPadding = UDim2.new(0, 10, 0, 10)
UIGridLayout.CellSize = UDim2.new(0, 125, 0, 135) -- Dynamic resizing handled below

-- Keep canvas size scaling automatically
UIGridLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, UIGridLayout.AbsoluteContentSize.Y + 15)
end)

-- Responsive grid element calculation when frame resizing happens
local function updateGridCellSizes()
    local frameWidth = ScrollFrame.AbsoluteSize.X
    -- Aim to fit columns cleanly depending on available width
    local columns = math.max(2, math.floor(frameWidth / 135))
    local padding = 10
    local availableWidth = frameWidth - (padding * (columns - 1)) - 6 -- Offset for Scrollbar
    local dynamicCellWidth = math.floor(availableWidth / columns)
    
    UIGridLayout.CellSize = UDim2.new(0, dynamicCellWidth, 0, dynamicCellWidth + 15)
end
ScrollFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateGridCellSizes)

