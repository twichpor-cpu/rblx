    [3] = { Name = "GOOD (~90%)",    MinOffset = -28, MaxOffset = 28 },
    [4] = { Name = "HUMANIZED (LEGIT)", MinOffset = 0, MaxOffset = 0 } -- Calculated dynamically per-note
}
local currentAccuracyIndex = 1

-- Release Thresholds (Distance past receptor before forcing key up)
local RELEASE_THRESHOLD_PX = 60

