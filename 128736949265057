-- -------------------------------------------------------------
-- DRAGGABLE SCRIPT FUNCTIONALITY
-- -------------------------------------------------------------
local dragging
local dragInput
local dragStart
local startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

table.insert(uiConnections, TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end))

table.insert(uiConnections, TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end))

table.insert(uiConnections, UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end))

-- -------------------------------------------------------------
-- BOT CORE AUTOPLAY LOGIC
-- -------------------------------------------------------------

-- Simulates keyboard key state securely
local function setKeyPressState(keyCode, isPressed)
    VirtualInputManager:SendKeyEvent(isPressed, keyCode, false, game)
end

-- Safely search for active path objects
local function getRhythmGameElements()
    local rhythmUI = PlayerGui:FindFirstChild("RhythmServiceUI")
    if not rhythmUI then return nil, nil end
    
    local root = rhythmUI:FindFirstChild("RhythmRoot")
    if not root then return nil, nil end
    
    local receptors = root:FindFirstChild("Receptors")
    local lanes = root:FindFirstChild("Lanes")
    
    return receptors, lanes
end

-- Matches notes to the nearest receptor horizontally
local function getAssociatedReceptor(note, receptors)
    local noteX = note.AbsolutePosition.X + (note.AbsoluteSize.X / 2)
    local closestReceptor = nil
    local minDistance = math.huge
    local matchedIndex = 1
    
    for i = 1, 4 do
        local receptor = receptors:FindFirstChild("Receptor" .. i)
        if receptor then
            local receptorX = receptor.AbsolutePosition.X + (receptor.AbsoluteSize.X / 2)
            local dist = math.abs(noteX - receptorX)
            if dist < minDistance then
                minDistance = dist
                closestReceptor = receptor
                matchedIndex = i
            end
        end
    end
    
    -- Ensure the note is actually aligned with a lane
    if minDistance < 60 then
        return closestReceptor, matchedIndex
    end
    return nil, nil
end

-- Generates randomized human-like performance offsets
local function getDynamicOffset()
    local mode = ACCURACY_MODES[currentAccuracyIndex]
    if mode.Name == "HUMANIZED (LEGIT)" then
        -- Weighted randomizer for realistic legitness (85% Perfect, 12% Great, 3% Good)
        local roll = math.random(1, 100)
        if roll <= 85 then
            return math.random(-6, 6) -- Perfect window
        elseif roll <= 97 then
            return math.random(-16, 16) -- Great window
        else
            return math.random(-26, 26) -- Good window
        end
    else
        return math.random(mode.MinOffset, mode.MaxOffset)
    end
end

-- Main Autoplay Thread
local function startProcessLoop()
    if processConnection then processConnection:Disconnect() end
    table.clear(playedNotes)
    table.clear(activeHolds)
    
    processConnection = RunService.Heartbeat:Connect(function()
        if not isProcessActive then return end
        
        local receptors, lanes = getRhythmGameElements()
        if not receptors or not lanes then
            StatusLabel.Text = "Waiting for Game UI components..."
            return
        end
        
        -- 1. Handle Active Key Holds (Release when note is gone, passed, or recycled)
        for noteInstance, holdData in pairs(activeHolds) do
            local shouldRelease = false
            
            if not noteInstance:IsDescendantOf(game) then
                shouldRelease = true
            else
                local targetNode = noteInstance:FindFirstChild("Head") or noteInstance
                local receptor = receptors:FindFirstChild("Receptor" .. holdData.keyIndex)
                
                if targetNode:IsA("GuiObject") and receptor then
                    local noteY = targetNode.AbsolutePosition.Y + (targetNode.AbsoluteSize.Y / 2)
                    local receptorY = receptor.AbsolutePosition.Y + (receptor.AbsoluteSize.Y / 2)
                    
                    -- Release if note passed the release boundary
                    if (noteY - receptorY) > RELEASE_THRESHOLD_PX then
                        shouldRelease = true
                    -- Release if note got recycled back to the top of the lane
                    elseif noteY < (receptorY - 100) then
                        shouldRelease = true
                    -- Release if the note was hidden/made invisible
                    elseif not targetNode.Visible then
                        shouldRelease = true
                    end
                else
                    shouldRelease = true
                end
            end
            
            if shouldRelease then
                activeHolds[noteInstance] = nil
                playedNotes[noteInstance] = true -- Mark note as completed
                
                -- Chord / Simultaneous Note Safeguard:
                -- Only physically release the key if NO OTHER active note is still holding it down
                local keyStillNeeded = false
                for _, otherHold in pairs(activeHolds) do
                    if otherHold.keyCode == holdData.keyCode then
                        keyStillNeeded = true
                        break
                    end
                end
                
                if not keyStillNeeded then
                    setKeyPressState(holdData.keyCode, false) -- RELEASE KEY
                end
                
                StatusLabel.Text = "Released: " .. holdData.keyCode.Name
            end
        end
        
        -- Clean up/Recycle playedNotes cache
        for noteInstance, _ in pairs(playedNotes) do
            if not noteInstance:IsDescendantOf(game) then
                playedNotes[noteInstance] = nil
            else
                local targetNode = noteInstance:FindFirstChild("Head") or noteInstance
                if targetNode:IsA("GuiObject") then
                    local receptor, keyIndex = getAssociatedReceptor(targetNode, receptors)
                    if receptor then
                        local noteY = targetNode.AbsolutePosition.Y + (targetNode.AbsoluteSize.Y / 2)
                        local receptorY = receptor.AbsolutePosition.Y + (receptor.AbsoluteSize.Y / 2)
                        
                        -- Object Recycling Check: If a "played" note is teleported back to the top,
                        -- remove it from playedNotes so it can be hit again!
                        if noteY < (receptorY - 100) then
                            playedNotes[noteInstance] = nil
                        end
                    end
                else
                    playedNotes[noteInstance] = nil
                end
            end
        end
        
        -- 2. Scan and Process Active Notes
        local descendants = lanes:GetDescendants()
        for _, obj in ipairs(descendants) do
            if obj.Name == "NoteTemplate" and not playedNotes[obj] and not activeHolds[obj] then
                local targetNode = obj:FindFirstChild("Head") or obj
                
                -- Static Template & Visibility Filter:
                -- Skip nodes that are hidden (.Visible = false) or have no size (often used for source templates)
                if targetNode:IsA("GuiObject") and targetNode.Visible and targetNode.AbsoluteSize.Y > 1 then
                    local receptor, keyIndex = getAssociatedReceptor(targetNode, receptors)
                    
                    if receptor then
                        local noteY = targetNode.AbsolutePosition.Y + (targetNode.AbsoluteSize.Y / 2)
                        local receptorY = receptor.AbsolutePosition.Y + (receptor.AbsoluteSize.Y / 2)
                        
                        -- Determine target distance using the selected accuracy Mode
                        local targetOffset = getDynamicOffset()
                        local triggerY = receptorY + targetOffset
                        
                        -- DIRECTIONAL CROSSING DETECTOR (Anti-Miss Engine):
                        -- We trigger the note if its center is passing through/has reached our target offset.
                        -- By checking a bracketed window slightly below/around the line, we guarantee 100% accuracy 
                        -- even if high-speed notes skip past the threshold between frames.
                        if noteY >= (triggerY - 20) and noteY <= (triggerY + 35) then
                            local keyToPress = KEY_MAPPINGS[keyIndex]
                            
                            if keyToPress then
                                setKeyPressState(keyToPress, true) -- HOLD KEY DOWN
                                activeHolds[obj] = { keyCode = keyToPress, keyIndex = keyIndex }
                                StatusLabel.Text = "Auto hit (" .. ACCURACY_MODES[currentAccuracyIndex].Name .. "): " .. keyToPress.Name
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function stopProcessLoop()
    if processConnection then
        processConnection:Disconnect()
        processConnection = nil
    end
    
    -- Safety cleanup: Release any keys that are currently being simulated down
    for _, holdData in pairs(activeHolds) do
        pcall(function()
            setKeyPressState(holdData.keyCode, false)
        end)
    end
    
    table.clear(activeHolds)
    table.clear(playedNotes)
    StatusLabel.Text = "Bot Idle - Awaiting Activation"
end

-- Accuracy cycling listener
table.insert(uiConnections, AccuracyButton.MouseButton1Click:Connect(function()
    currentAccuracyIndex = currentAccuracyIndex + 1
    if currentAccuracyIndex > #ACCURACY_MODES then
        currentAccuracyIndex = 1
    end
    
    local mode = ACCURACY_MODES[currentAccuracyIndex]
    AccuracyButton.Text = "ACCURACY: " .. mode.Name
end))

-- Toggle click listener
table.insert(uiConnections, ToggleButton.MouseButton1Click:Connect(function()
    isProcessActive = not isProcessActive
    
    if isProcessActive then
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50) -- Green
        ToggleButton.Text = "AUTOPLAY: ON"
        startProcessLoop()
    else
        ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50) -- Red
        ToggleButton.Text = "AUTOPLAY: OFF"
        stopProcessLoop()
    end
end))

-- Close click listener (Deactivates loops, removes connections, destroys UI)
table.insert(uiConnections, CloseButton.MouseButton1Click:Connect(function()
    isProcessActive = false
    stopProcessLoop()
    
    -- Disconnect UI Event listeners to prevent memory leaks
    for _, connection in ipairs(uiConnections) do
        if connection then
            connection:Disconnect()
        end
    end
    table.clear(uiConnections)
    
    -- Destroy GUI Element
    ScreenGui:Destroy()
end))
