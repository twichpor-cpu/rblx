-- Draggable Functionality
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

table.insert(uiConnections, TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end))

table.insert(uiConnections, TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end))

table.insert(uiConnections, UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end))

-- -------------------------------------------------------------
-- HISTORICAL LOG ENGINE
-- -------------------------------------------------------------
local maxLogs = 30
local logCount = 0

local function addHistoryLog(text, color)
    color = color or Color3.fromRGB(200, 200, 200)
    logCount = logCount + 1
    
    local logLabel = Instance.new("TextLabel")
    logLabel.Size = UDim2.new(1, -10, 0, 16)
    logLabel.BackgroundTransparency = 1
    logLabel.Font = Enum.Font.Code
    logLabel.Text = " " .. text
    logLabel.TextColor3 = color
    logLabel.TextSize = 11
    logLabel.TextXAlignment = Enum.TextXAlignment.Left
    logLabel.LayoutOrder = logCount
    logLabel.Parent = LogContainer
    
    -- Keep memory clean by removing oldest labels
    local children = LogContainer:GetChildren()
    local labels = {}
    for _, c in ipairs(children) do
        if c:IsA("TextLabel") then
            table.insert(labels, c)
        end
    end
    
    if #labels > maxLogs then
        table.sort(labels, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
        labels[1]:Destroy()
    end
    
    -- Auto scrolls log box to the bottom
    task.defer(function()
        LogContainer.CanvasPosition = Vector2.new(0, LogContainer.AbsoluteCanvasSize.Y)
    end)
end

-- -------------------------------------------------------------
-- TRULY DYNAMIC KEYBIND ENGINE
-- -------------------------------------------------------------

local function getKeyCodeFromText(text)
    if not text or text == "" then return nil end
    
    -- Strip HTML/RichText tags (e.g. <font color="...">F</font> -> F)
    local clean = text:gsub("<[^>]+>", "")
    
    -- Format to match Enum naming conventions (Uppercase, remove spaces/punctuation brackets/quotes)
    clean = string.upper(clean):gsub("[%[%]%{%}%(%)%s%c%p]", "")
    if clean == "" then return nil end
    
    -- TRULY DYNAMIC LOOKUP: Checks Enum.KeyCode directly for the key name
    local success, key = pcall(function()
        return Enum.KeyCode[clean]
    end)
    if success and key then return key end
    
    -- Fallback maps for numerical keys
    local numberMap = {
        ["1"] = Enum.KeyCode.One, ["2"] = Enum.KeyCode.Two, ["3"] = Enum.KeyCode.Three,
        ["4"] = Enum.KeyCode.Four, ["5"] = Enum.KeyCode.Five, ["6"] = Enum.KeyCode.Six,
        ["7"] = Enum.KeyCode.Seven, ["8"] = Enum.KeyCode.Eight, ["9"] = Enum.KeyCode.Nine,
        ["0"] = Enum.KeyCode.Zero
    }
    if numberMap[clean] then return numberMap[clean] end

    -- Fallback maps for special directional and function keys
    local specialMap = {
        ["UPARROW"] = Enum.KeyCode.Up, ["DOWNARROW"] = Enum.KeyCode.Down,
        ["LEFTARROW"] = Enum.KeyCode.Left, ["RIGHTARROW"] = Enum.KeyCode.Right,
        ["UP"] = Enum.KeyCode.Up, ["DOWN"] = Enum.KeyCode.Down,
        ["LEFT"] = Enum.KeyCode.Left, ["RIGHT"] = Enum.KeyCode.Right,
        ["SPACEBAR"] = Enum.KeyCode.Space, ["SPACE"] = Enum.KeyCode.Space,
        ["LSHIFT"] = Enum.KeyCode.LeftShift, ["RSHIFT"] = Enum.KeyCode.RightShift,
        ["SHIFT"] = Enum.KeyCode.LeftShift, ["LCTRL"] = Enum.KeyCode.LeftControl,
        ["RCTRL"] = Enum.KeyCode.RightControl, ["CTRL"] = Enum.KeyCode.LeftControl,
        ["LALT"] = Enum.KeyCode.LeftAlt, ["RALT"] = Enum.KeyCode.RightAlt,
        ["ALT"] = Enum.KeyCode.LeftAlt
    }
    
    return specialMap[clean]
end

local function setKeyPressState(keyCode, isPressed)
    if not keyCode then return end
    VirtualInputManager:SendKeyEvent(isPressed, keyCode, false, game)
end

local function getRhythmGameElements()
    local rhythmUI = PlayerGui:FindFirstChild("RhythmServiceUI")
    if not rhythmUI then return nil, nil end
    local root = rhythmUI:FindFirstChild("RhythmRoot")
    if not root then return nil, nil end
    return root:FindFirstChild("Receptors"), root:FindFirstChild("Lanes")
end

-- Grabs any layout/lane count dynamically (strictly filters names matching Receptor[num])
local function getActiveReceptorsList(receptorsFolder)
    local list = {}
    if not receptorsFolder then return list end
    for _, child in ipairs(receptorsFolder:GetChildren()) do
        -- Pattern matching looks for child named exactly "Receptor" followed by numbers
        if child:IsA("GuiObject") and string.match(child.Name, "^Receptor%d+$") then
            table.insert(list, child)
        end
    end
    return list
end

-- Safely updates key bindings cache from receptors
local function updateReceptorKeys(activeReceptors)
    for _, receptor in ipairs(activeReceptors) do
        local keyLabel = receptor:FindFirstChild("KeyHint")
        if keyLabel then
            -- Safely pull text content
            local text = keyLabel.ContentText
            if not text or text == "" then
                text = keyLabel.Text
            end
            
            if text and text ~= "" then
                local key = getKeyCodeFromText(text)
                if key then
                    if receptorKeyMap[receptor.Name] ~= key then
                        receptorKeyMap[receptor.Name] = key
                        addHistoryLog("Mapped " .. receptor.Name .. " to key: " .. key.Name, Color3.fromRGB(120, 180, 255))
                    end
                end
            end
        end
    end
end

local function getScrollDirection(receptor)
    local screenHeight = 1080
    local rhythmUI = PlayerGui:FindFirstChild("RhythmServiceUI")
    if rhythmUI and rhythmUI:IsA("GuiObject") then
        screenHeight = rhythmUI.AbsoluteSize.Y
    end
    return (receptor.AbsolutePosition.Y < (screenHeight * 0.45)) and "Up" or "Down"
end

local function getNoteTrailingEdgeY(note, scrollDirection)
    local trailingY = nil
    local parts = {note}
    pcall(function()
        for _, child in ipairs(note:GetDescendants()) do
            if child:IsA("GuiObject") and child.Visible and child.Name ~= "Head" then
                table.insert(parts, child)
            end
        end
    end)
    for _, part in ipairs(parts) do
        local partY = part.AbsolutePosition.Y
        local partHeight = part.AbsoluteSize.Y
        if scrollDirection == "Up" then
            local bottomY = partY + partHeight
            if not trailingY or bottomY > trailingY then trailingY = bottomY end
        else
            local topY = partY
            if not trailingY or topY < trailingY then trailingY = topY end
        end
    end
    return trailingY
end

-- Matches Note horizontally to dynamically aligned Receptors
local function getAssociatedReceptor(note, activeReceptors)
    local noteX = note.AbsolutePosition.X + (note.AbsoluteSize.X / 2)
    local closestReceptor = nil
    local minDistance = math.huge
    for _, receptor in ipairs(activeReceptors) do
        local receptorX = receptor.AbsolutePosition.X + (receptor.AbsoluteSize.X / 2)
        local dist = math.abs(noteX - receptorX)
        if dist < minDistance then
            minDistance = dist
            closestReceptor = receptor
        end
    end
    return (minDistance < 60) and closestReceptor or nil
end

local function getDynamicOffset()
    local mode = ACCURACY_MODES[currentAccuracyIndex]
    if mode.Name == "HUMANIZED (LEGIT)" then
        local roll = math.random(1, 100)
        if roll <= 85 then return math.random(-6, 6)
        elseif roll <= 97 then return math.random(-16, 16)
        else return math.random(-26, 26) end
    else
        return math.random(mode.MinOffset, mode.MaxOffset)
    end
end

-- Main Heartbeat Loop
local function startProcessLoop()
    if processConnection then processConnection:Disconnect() end
    table.clear(playedNotes)
    table.clear(activeHolds)
    table.clear(receptorKeyMap)
    
    addHistoryLog("Autoplay Active. Scanning lanes...", Color3.fromRGB(100, 255, 100))

    processConnection = RunService.Heartbeat:Connect(function()
        if not isProcessActive then return end
        
        local receptorsFolder, lanes = getRhythmGameElements()
        if not receptorsFolder or not lanes then
            StatusLabel.Text = "Waiting for Game UI components..."
            return
        end
        
        local activeReceptors = getActiveReceptorsList(receptorsFolder)
        if #activeReceptors == 0 then
            StatusLabel.Text = "No active lanes detected."
            return
        end
        
        -- Continuously update our key map cache from visual cues (safe & fail-safe)
        updateReceptorKeys(activeReceptors)
        
        -- 1. Handle Active Key Holds & Trailing-edge releases
        for noteInstance, holdData in pairs(activeHolds) do
            local shouldRelease = false
            if not noteInstance:IsDescendantOf(game) then
                shouldRelease = true
            else
                local targetNode = noteInstance:FindFirstChild("Head") or noteInstance
                local receptor = receptorsFolder:FindFirstChild(holdData.receptorName)
                if receptor then
                    local receptorY = receptor.AbsolutePosition.Y + (receptor.AbsoluteSize.Y / 2)
                    local scrollDirection = getScrollDirection(receptor)
                    
                    if not holdData.isHold then
                        if (os.clock() - holdData.pressTime) >= 0.05 then shouldRelease = true end
                    else
                        local trailingY = getNoteTrailingEdgeY(noteInstance, scrollDirection)
                        if trailingY then
                            if scrollDirection == "Up" then
                                if trailingY < (receptorY - 10) then shouldRelease = true end
                            else
                                if trailingY > (receptorY + 10) then shouldRelease = true end
                            end
                        else
                            shouldRelease = true
                        end
                    end
                    
                    -- Boundaries
                    local currentY = targetNode.AbsolutePosition.Y + (targetNode.AbsoluteSize.Y / 2)
                    if scrollDirection == "Up" then
                        if currentY > (receptorY + 100) then shouldRelease = true end
                    else
                        if currentY < (receptorY - 100) then shouldRelease = true end
                    end
                    
                    if not noteInstance.Visible then shouldRelease = true end
                else
                    shouldRelease = true
                end
            end
            
            if shouldRelease then
                activeHolds[noteInstance] = nil
                playedNotes[noteInstance] = true
                
                -- Chord Safeguard
                local keyStillNeeded = false
                for _, otherHold in pairs(activeHolds) do
                    if otherHold.keyCode == holdData.keyCode then
                        keyStillNeeded = true
                        break
                    end
                end
                if not keyStillNeeded then
                    setKeyPressState(holdData.keyCode, false)
                end
                if holdData.keyCode then
                    StatusLabel.Text = "Released: " .. holdData.keyCode.Name
                    addHistoryLog("UP: " .. holdData.keyCode.Name, Color3.fromRGB(255, 120, 120))
                end
            end
        end
        
        -- Recycle cache
        for noteInstance, _ in pairs(playedNotes) do
            if not noteInstance:IsDescendantOf(game) then
                playedNotes[noteInstance] = nil
            else
                local targetNode = noteInstance:FindFirstChild("Head") or noteInstance
                if targetNode:IsA("GuiObject") then
                    local receptor = getAssociatedReceptor(targetNode, activeReceptors)
                    if receptor then
                        local receptorY = receptor.AbsolutePosition.Y + (receptor.AbsoluteSize.Y / 2)
                        local currentY = targetNode.AbsolutePosition.Y + (targetNode.AbsoluteSize.Y / 2)
                        local scrollDirection = getScrollDirection(receptor)
                        
                        if scrollDirection == "Up" then
                            if currentY > (receptorY + 100) then playedNotes[noteInstance] = nil end
                        else
                            if currentY < (receptorY - 100) then playedNotes[noteInstance] = nil end
                        end
                    end
                else
                    playedNotes[noteInstance] = nil
                end
            end
        end
        
        -- 2. Scan and Autoplay Notes
        local descendants = lanes:GetDescendants()
        for _, obj in ipairs(descendants) do
            if obj.Name == "NoteTemplate" and not playedNotes[obj] and not activeHolds[obj] then
                local targetNode = obj:FindFirstChild("Head") or obj
                if targetNode:IsA("GuiObject") and targetNode.Visible and targetNode.AbsoluteSize.Y > 1 then
                    local receptor = getAssociatedReceptor(targetNode, activeReceptors)
                    if receptor then
                        local noteY = targetNode.AbsolutePosition.Y + (targetNode.AbsoluteSize.Y / 2)
                        local receptorY = receptor.AbsolutePosition.Y + (receptor.AbsoluteSize.Y / 2)
                        local targetOffset = getDynamicOffset()
                        local triggerY = receptorY + targetOffset
                        
                        if noteY >= (triggerY - 20) and noteY <= (triggerY + 35) then
                            -- READS THE RECEPTOR'S KEYCODE DIRECTLY FROM THE DYNAMIC KEYMAP CACHE
                            local keyToPress = receptorKeyMap[receptor.Name]
                            
                            if keyToPress then
                                local isHold = false
                                if obj.AbsoluteSize.Y > 65 then
                                    isHold = true
                                else
                                    for _, child in ipairs(obj:GetDescendants()) do
                                        if child:IsA("GuiObject") and child.Visible and child.Name ~= "Head" and child.AbsoluteSize.Y > 15 then
                                            isHold = true
                                            break
                                        end
                                    end
                                end
                                
                                setKeyPressState(keyToPress, true)
                                activeHolds[obj] = { 
                                    keyCode = keyToPress, 
                                    receptorName = receptor.Name,
                                    isHold = isHold,
                                    pressTime = os.clock()
                                }
                                StatusLabel.Text = "Auto hit (" .. (isHold and "Hold" or "Tap") .. "): " .. keyToPress.Name
                                addHistoryLog("DOWN: " .. keyToPress.Name .. (isHold and " (Hold)" or ""), Color3.fromRGB(120, 255, 120))
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function stopProcessLoop()
    if processConnection then
        processConnection:Disconnect()
        processConnection = nil
    end
    for _, holdData in pairs(activeHolds) do
        pcall(function() setKeyPressState(holdData.keyCode, false) end)
    end
    table.clear(activeHolds)
    table.clear(playedNotes)
    table.clear(receptorKeyMap)
    StatusLabel.Text = "Bot Idle - Awaiting Activation"
    addHistoryLog("Autoplay Stopped.", Color3.fromRGB(255, 180, 100))
end

